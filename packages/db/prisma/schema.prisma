// ============================================================================
// ADIANTAMENTOS — CONTA CORRENTE DE ADIANTAMENTO (CLIENTE / FORNECEDOR)
// ============================================================================

enum AdiantamentoTipo {
  CLIENTE      // Adiantamento recebido de cliente
  FORNECEDOR   // Adiantamento pago a fornecedor
}

enum AdiantamentoMovTipo {
  CREDITO  // Entrada de valor (recebimento/pagamento antecipado)
  DEBITO   // Aplicação do adiantamento contra faturamento
}

enum AdiantamentoStatus {
  ATIVO      // Saldo disponível
  ENCERRADO  // Saldo zerado
  CANCELADO
}

model Adiantamento {
  id              String             @id @default(cuid())
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id])
  personId        String
  person          Person             @relation("PersonAdiantamentos", fields: [personId], references: [id])
  tipo            AdiantamentoTipo
  descricao       String?            @db.Text
  saldoTotal      Decimal            @default(0) @db.Decimal(15, 2)  // soma dos CREDITOs
  saldoUtilizado  Decimal            @default(0) @db.Decimal(15, 2)  // soma dos DÉBITOs
  saldoDisponivel Decimal            @default(0) @db.Decimal(15, 2)  // saldoTotal - saldoUtilizado
  status          AdiantamentoStatus @default(ATIVO)
  observations    String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  movimentos      AdiantamentoMovimento[]

  @@unique([companyId, personId, tipo])
  @@index([companyId, tipo, status])
  @@map("adiantamentos")
}

model AdiantamentoMovimento {
  id              String              @id @default(cuid())
  adiantamentoId  String
  adiantamento    Adiantamento        @relation(fields: [adiantamentoId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])
  tipo            AdiantamentoMovTipo
  valor           Decimal             @db.Decimal(15, 2)
  data            DateTime
  descricao       String              @db.Text
  referencia      String?             @db.VarChar(100)  // nº NF, nº pedido, etc.
  bankAccountId   String?
  bankAccount     BankAccount?        @relation(fields: [bankAccountId], references: [id])
  paymentMethod   PaymentMethod?
  userId          String
  user            User                @relation("AdiantamentoMovimentoUser", fields: [userId], references: [id])
  journalEntryId  String?
  journalEntry    JournalEntry?       @relation("AdiantamentoMovJournal", fields: [journalEntryId], references: [id])
  observations    String?             @db.Text
  createdAt       DateTime            @default(now())

  @@index([adiantamentoId, tipo])
  @@map("adiantamento_movimentos")
}

// ============================================================================
// ALÍQUOTAS CONFIGURÁVEIS POR EMPRESA / REGIME
// ============================================================================

model CompanyTaxRate {
  id             String    @id @default(cuid())
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  regime         TaxRegime
  aliquotaPis    Float     @default(0.65)
  aliquotaCofins Float     @default(3.0)
  aliquotaIss    Float     @default(5.0)
  aliquotaCsll   Float     @default(1.0)
  aliquotaIr     Float     @default(1.5)
  aliquotaInss   Float     @default(0.0)
  // Reforma Tributária — CBS/IBS por regime (default 0 = reform not yet active)
  aliquotaCbs    Float     @default(0.0)  // CBS substitui PIS+COFINS (LC 214/2025)
  aliquotaIbs    Float     @default(0.0)  // IBS substitui ICMS+ISS (LC 214/2025)
  vigenciaInicio DateTime  @default(now())
  vigenciaFim    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("company_tax_rates")
}

model TaxRetentionConfig {
  id          String    @id @default(cuid())
  companyId   String    @unique
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Valores mínimos para retenção (IN RFB 2.145/2023)
  minimoRetencaoPisCofinsCsll  Float  @default(215.05)  // R$215,05 - mínimo mensal
  minimoRetencaoIrrf           Float  @default(10.00)   // R$10,00 por documento
  minimoRetencaoInss           Float  @default(0.00)    // sem mínimo por padrão
  minimoRetencaoIss            Float  @default(0.00)    // configurável por município

  // Reforma Tributária (EC 132/2023 + LC 214/2025)
  usarSistemaNovo              Boolean  @default(false)  // ativar CBS/IBS (reforma)
  periodoReforma               String?  @db.VarChar(20)  // "TESTE_2026", "CBS_2027", "TRANSICAO", "PLENA_2033"
  aliquotaCbs                  Float    @default(0.9)    // CBS - substitui PIS+COFINS (2026: 0,9% teste; 2027+: ~9,25%)
  aliquotaIbs                  Float    @default(0.1)    // IBS - substitui ISS (2026: 0,1% teste; 2033: alíquota plena)
  // CSLL e IRRF não são afetados pela reforma
  // INSS não é afetado pela reforma

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("tax_retention_configs")
}

// ============================================================================
// NFS-e — NOTA FISCAL DE SERVIÇO ELETRÔNICA (API Nacional RFB)
// ============================================================================

enum NfseStatus {
  PENDENTE
  AUTORIZADA
  CANCELADA
  REJEITADA
  RECEBIDA
  ESCRITURADA
}

model NbsCode {
  id                 String   @id @default(cuid())
  codigo             String   @unique @db.VarChar(20)
  descricao          String   @db.VarChar(500)
  unidade            String?  @db.VarChar(50)
  aliquotaIss        Float?
  aliquotaIrrf       Float    @default(1.5)   // alíquota IRRF específica do serviço
  requerRetencaoInss Boolean  @default(false)  // serviço envolve cessão de mão de obra
  ativo              Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  nfseEmitidas  NfseEmitida[]
  nfseRecebidas NfseRecebida[]

