// ============================================================================
// PATRIMÔNIO / ATIVO IMOBILIZADO
// ============================================================================

enum FixedAssetStatus {
  ATIVO
  BAIXADO
  EM_MANUTENCAO
}

enum FixedAssetType {
  MAQUINA_EQUIPAMENTO
  VEICULO
  MOVEL_UTENSILIO
  IMOVEL
  INFORMATICA
  FERRAMENTA
  OUTRO
}

model FixedAsset {
  id                        String           @id @default(cuid())
  companyId                 String
  company                   Company          @relation(fields: [companyId], references: [id])

  // Identificação
  plaqueta                  String           @db.VarChar(30)   // número da plaqueta patrimonial
  descricao                 String           @db.VarChar(200)
  type                      FixedAssetType   @default(MAQUINA_EQUIPAMENTO)
  marca                     String?          @db.VarChar(60)
  modelo                    String?          @db.VarChar(60)
  numeroserie               String?          @db.VarChar(60)

  // Localização / Centro de Custo
  localizacao               String?          @db.VarChar(100)  // local físico na fábrica
  costCenterCode            CostCenterCode   @default(CC_IND)

  // Aquisição
  dataAquisicao             DateTime
  fornecedor                String?          @db.VarChar(100)
  notaFiscal                String?          @db.VarChar(50)
  valorAquisicao            Decimal          @db.Decimal(15, 2)

  // Depreciação
  vidaUtilMeses             Int              // vida útil em meses (ex: 60 = 5 anos)
  taxaDepreciacaoMensal     Decimal          @db.Decimal(8, 6) // % mensal = 1/vidaUtilMeses
  valorDepreciacaoAcumulada Decimal          @default(0) @db.Decimal(15, 2)
  valorResidual             Decimal          @db.Decimal(15, 2) // valorAquisicao - depreciado
  mesInicioDepreciacao      DateTime         // primeiro mês de depreciação
  ultimaDepreciacaoEm       DateTime?        // última vez que rodou o cálculo

  // CIAP — Crédito ICMS Ativo Imobilizado (art. 20 LC 87/96 — 1/48 por mês)
  icmsNaEntrada         Decimal?  @db.Decimal(15, 2)  // ICMS pago na aquisição — base do CIAP
  parcelasIcmsCiap      Int       @default(48)          // total de parcelas (normalmente 48)
  parcelasApropriadas   Int       @default(0)           // parcelas CIAP já aproveitadas
  ciapAtivo             Boolean   @default(false)        // true = bem imobilizado sob controle CIAP
  nfeEntradaChave       String?   @db.VarChar(60)        // chave NF-e de aquisição (para Bloco G)
  nfeEntradaNumero      String?   @db.VarChar(50)        // número NF-e de aquisição

  // Status
  status                    FixedAssetStatus @default(ATIVO)
  dataBaixa                 DateTime?
  motivoBaixa               String?          @db.VarChar(200)

  observacoes               String?          @db.Text
  active                    Boolean          @default(true)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  depreciacoes              FixedAssetDepreciation[]
  maintenances              FixedAssetMaintenance[]
  ciapMovimentos            CiapMovimento[]

  @@unique([companyId, plaqueta])
  @@index([companyId, status])
  @@map("fixed_assets")
}

model FixedAssetDepreciation {
  id              String     @id @default(cuid())
  companyId       String
  assetId         String
  asset           FixedAsset @relation(fields: [assetId], references: [id])

  ano             Int        // ex: 2026
  mes             Int        // 1-12
  valorDepreciacao Decimal   @db.Decimal(15, 2)
  valorAcumulado  Decimal    @db.Decimal(15, 2)
  valorResidual   Decimal    @db.Decimal(15, 2)
  lancadoGGF      Boolean    @default(false)  // se já foi lançado como GGF
  processadoEm    DateTime   @default(now())

  @@unique([assetId, ano, mes])
  @@map("fixed_asset_depreciations")
}

// ============================================================================
// CIAP — Controle de Crédito de ICMS do Ativo Permanente (A10)
// ============================================================================

model CiapMovimento {
  id              String     @id @default(cuid())
  companyId       String
  assetId         String
  asset           FixedAsset @relation(fields: [assetId], references: [id])

  ano             Int                             // ex: 2026
  mes             Int                             // 1-12
  parcelaNumero   Int                             // 1..48 (ou parcelasIcmsCiap)
  valorCredito    Decimal    @db.Decimal(15, 2)   // icmsNaEntrada / parcelasIcmsCiap
  aproveitado     Boolean    @default(false)       // se foi lançado no período
  processadoEm    DateTime?

  createdAt       DateTime   @default(now())

  @@unique([assetId, ano, mes])
  @@index([companyId, ano, mes])
  @@map("ciap_movimentos")
}

// ============================================================================
// MANUTENÇÃO DE ATIVOS PATRIMONIAIS
// ============================================================================

enum MaintenanceType {
  PREVENTIVA
  CORRETIVA
  PREDITIVA
  LUBRIFICACAO
  CALIBRACAO
  INSPECAO
  OUTRO
}

enum MaintenanceStatus {
  ABERTA
  EM_EXECUCAO
  AGUARDANDO_RETORNO   // enviado para manutenção externa, aguardando retorno
  CONCLUIDA
  CANCELADA
}

enum MaintenanceLocation {
  INTERNA    // executada dentro da empresa
  EXTERNA    // ativo enviado para fornecedor externo
}

model FixedAssetMaintenance {
  id                  String              @id @default(cuid())
  companyId           String
  assetId             String
  asset               FixedAsset          @relation(fields: [assetId], references: [id])

  // Identificação
  numero              String              @db.VarChar(20)   // MAT-2026-0001
  type                MaintenanceType
  status              MaintenanceStatus   @default(ABERTA)
  local               MaintenanceLocation @default(INTERNA)

  // Datas
  dataAbertura        DateTime            @default(now())
  dataEnvio           DateTime?           // quando enviou ao fornecedor (externa)
  dataRetornoPrevista DateTime?           // prazo combinado de retorno
  dataRetornoReal     DateTime?           // quando o ativo voltou de fato
  dataConclusao       DateTime?

  // Fornecedor
  fornecedorId        String?             // FK para Person
  fornecedorNome      String?             @db.VarChar(100) // fallback se não cadastrado

  // Fiscal
  notaFiscalRemessa   String?             @db.VarChar(50)  // NF de saída do ativo
  notaFiscalRetorno   String?             @db.VarChar(50)  // NF de retorno do ativo
  notaFiscalServico   String?             @db.VarChar(50)  // NF do serviço prestado

  // Valores
  valorServico        Decimal?            @db.Decimal(15, 2)
  valorPecas          Decimal?            @db.Decimal(15, 2)

  // Descrição
  descricaoProblema   String?             @db.Text   // problema relatado / motivo
  descricaoServico    String?             @db.Text   // o que foi feito
  observacoes         String?             @db.Text

  // Relações
  anexos              MaintenanceAttachment[]

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([companyId, numero])
  @@index([assetId, status])
  @@map("fixed_asset_maintenances")
}

model MaintenanceAttachment {
  id              String                @id @default(cuid())
  maintenanceId   String
  maintenance     FixedAssetMaintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)
  fileName        String                @db.VarChar(255)
  originalName    String                @db.VarChar(255)
  fileUrl         String                @db.VarChar(500)   // URL MinIO
  fileSize        Int                   // bytes
  mimeType        String                @db.VarChar(100)
  bucket          String                @db.VarChar(100)
  objectKey       String                @db.VarChar(500)   // key no MinIO
  uploadedAt      DateTime              @default(now())

  @@map("maintenance_attachments")
}

// ============================================================================
// FASE 1 — SISTEMA DE APROVAÇÕES CONFIGURÁVEL
// ============================================================================

enum ApprovalModule {
  COMPRAS
  VENDAS
  RH
  FINANCEIRO
  ESTOQUE
}

enum ApprovalDocumentType {
  SOLICITACAO_COMPRA
  COTACAO
  ORDEM_COMPRA
  PEDIDO_VENDA
  PAGAMENTO
  FOLHA_PAGAMENTO
  REQUISICAO
  FERIAS
  ADMISSAO
  DEMISSAO
  AJUSTE_ESTOQUE
}

enum ApprovalTriggerType {
  SEMPRE         // Sempre exige aprovação
  VALOR_ACIMA    // Apenas quando valor > gatilhoValor
  PERCENTUAL_ACIMA // Apenas quando % > gatilhoValor (ex: desconto)
}

enum ApprovalExpiredAction {
  ESCALAR        // Sobe para o próximo nível
  REJEITAR       // Rejeita automaticamente
  APROVAR_AUTO   // Aprova automaticamente (sem ação do aprovador)
}

enum ApprovalStatus {
  PENDENTE
  APROVADO
  REJEITADO
  CANCELADO
}

enum ApprovalActionType {
  APROVADO
  REJEITADO
  ESCALADO
  CANCELADO
}

/// Regra de aprovação por módulo/tipo de documento
model ApprovalPolicy {
  id              String               @id @default(cuid())
  companyId       String
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  module          ApprovalModule
  documentType    ApprovalDocumentType
  enabled         Boolean              @default(false)
  triggerType     ApprovalTriggerType  @default(SEMPRE)
  triggerValue    Decimal?             @db.Decimal(15, 2)
  description     String?              @db.VarChar(255)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  levels          ApprovalLevel[]
  requests        ApprovalRequest[]

  @@unique([companyId, module, documentType])
  @@map("approval_policies")
}

/// Nível hierárquico de uma regra (Supervisor → Gerente → Diretor)
model ApprovalLevel {
  id               String                @id @default(cuid())
  policyId         String
  policy           ApprovalPolicy        @relation(fields: [policyId], references: [id], onDelete: Cascade)
  ordem            Int                   // 1, 2, 3...
  roleId           String
  role             Role                  @relation(fields: [roleId], references: [id])
  prazoHoras       Int                   @default(24)
  acaoEsgotado     ApprovalExpiredAction @default(ESCALAR)
  createdAt        DateTime              @default(now())

  @@unique([policyId, ordem])
  @@map("approval_levels")
}

/// Instância de aprovação para um documento específico
model ApprovalRequest {
  id             String               @id @default(cuid())
  companyId      String
  company        Company              @relation(fields: [companyId], references: [id])
  policyId       String
  policy         ApprovalPolicy       @relation(fields: [policyId], references: [id])
  module         ApprovalModule
  documentType   ApprovalDocumentType
  documentId     String               // ID do documento (OC, SC, etc.)
  status         ApprovalStatus       @default(PENDENTE)
  nivelAtual     Int                  @default(1)
  totalNiveis    Int
  solicitanteId  String
  solicitante    User                 @relation("ApprovalRequests", fields: [solicitanteId], references: [id])
  valorDocumento Decimal?             @db.Decimal(15, 2)
  criadoEm       DateTime             @default(now())
  resolvidoEm    DateTime?
  expiradoEm     DateTime?

  actions        ApprovalAction[]

  @@index([companyId, status])
  @@index([companyId, documentType, documentId])
  @@map("approval_requests")
}

/// Log de cada ação de aprovação/rejeição
model ApprovalAction {
  id                String             @id @default(cuid())
  approvalRequestId String
  approvalRequest   ApprovalRequest    @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  nivelOrdem        Int
  userId            String
  user              User               @relation("ApprovalActions", fields: [userId], references: [id])
  roleId            String
  role              Role               @relation("ApprovalActionRole", fields: [roleId], references: [id])
  acao              ApprovalActionType
  comentario        String?            @db.Text
  atuadoEm          DateTime           @default(now())

  @@map("approval_actions")
}

// ============================================================================
// AUDITORIA DE DIVERGÊNCIAS NCM
// ============================================================================

model NcmAuditoria {
  id               String       @id @default(cuid())
  companyId        String
  company          Company      @relation(fields: [companyId], references: [id])
  nfeInboxId       String
  nfeInbox         NFeInbox     @relation(fields: [nfeInboxId], references: [id])
  nfeInboxItemId   String
  nfeInboxItem     NFeInboxItem @relation(fields: [nfeInboxItemId], references: [id])
  productId        String
  product          Product      @relation(fields: [productId], references: [id])
  ncmNota          String       @db.VarChar(10)
  ncmCadastro      String       @db.VarChar(10)
  status           String       @default("PENDENTE") @db.VarChar(20)
  origemErro       String?      @db.VarChar(20)
  observacoes      String?      @db.Text
  resolvidoEm      DateTime?
  resolvidoPorId   String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([companyId, status])
  @@index([nfeInboxId])
  @@map("ncm_auditorias")
}

// ============================================================================
// SPRINT 2 — ERP DINÂMICO: SOFT LOCK · APROVAÇÃO PARCIAL · TIMELINE · RESERVA
// ============================================================================

// ── 2.1 — Soft Lock por Campo ──────────────────────────────────────────────

/// Configura quais campos ficam travados por tipo de documento e status.
/// Campos fiscais travam automaticamente; campos operacionais ficam livres.
model DocumentFieldLock {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  entityType    String   @db.VarChar(100)  // "SaleOrder" | "PurchaseOrder" | "ProductionOrder" | "Requisition"
  fromStatus    String   @db.VarChar(50)   // status a partir do qual as regras se aplicam

  lockedFields  String[]                   // campos imutáveis neste status
  freeFields    String[]                   // campos sempre editáveis (sobrescreve lockedFields)
  requireMotivo Boolean  @default(false)   // true = exige motivoAlteracao para alterar freeFields

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, entityType, fromStatus])
  @@index([companyId, entityType])
  @@map("document_field_locks")
}

// ── 2.2 — Status de aprovação por item ────────────────────────────────────

enum ItemApprovalStatus {
  PENDENTE
  APROVADO
  REJEITADO
  AGUARDANDO_COMPRA
}

// ── 2.3 — Linha do Tempo de Documento ─────────────────────────────────────

enum DocumentEventType {
  CRIADO
  ALTERADO
  STATUS_MUDOU
  APROVADO
  REJEITADO
  COMENTARIO
  DOCUMENTO_VINCULADO
  ALERTA_GERADO
  ITEM_APROVADO
  ITEM_REJEITADO
  RESERVA_CRIADA
  RESERVA_LIBERADA
  RESERVA_CONSUMIDA
}

/// Histórico navegável de qualquer documento do ERP.
/// Alimentado pelo DocumentEventService nos pontos-chave de cada processo.
model DocumentEvent {
  id              String            @id @default(cuid())
  companyId       String
  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  entityType      String            @db.VarChar(100)  // "SaleOrder" | "ProductionOrder" | etc.
  entityId        String            @db.VarChar(100)
  eventType       DocumentEventType
  fieldChanged    String?           @db.VarChar(100)
  oldValue        Json?
  newValue        Json?
  motivoAlteracao String?           @db.Text
  description     String?           @db.Text          // texto livre opcional

  userId          String?
  user            User?             @relation(fields: [userId], references: [id])
  ipAddress       String?           @db.VarChar(50)

  createdAt       DateTime          @default(now())

  @@index([entityType, entityId])
  @@index([companyId, createdAt])
  @@map("document_events")
}

// ── 2.4 — Reserva de Estoque (OP / OS / Pedido de Venda) ──────────────────

enum StockReservationStatus {
  ATIVA        // reserva ativa, quantidade indisponível
  LIBERADA     // reserva liberada manualmente (OP/OS cancelada etc.)
  CONSUMIDA    // material efetivamente consumido/expedido
  CANCELADA    // cancelada sem consumo
}

enum StockReservationSource {
  PRODUCTION_ORDER  // Ordem de Produção
  SERVICE_ORDER     // Ordem de Serviço (Oficina)
  SALE_ORDER        // Pedido de Venda (produtos acabados / revenda)
}

/// Reserva de estoque vinculada a uma OP, OS ou Pedido de Venda.
/// Garante que múltiplos documentos não compitam pelo mesmo saldo.
/// availableQuantity (StockBalance) = quantity - SUM(reservas ATIVAS)
model StockReservation {
  id          String                 @id @default(cuid())
  companyId   String
  company     Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId   String
  product     Product                @relation(fields: [productId], references: [id])
  locationId  String
  location    StockLocation          @relation(fields: [locationId], references: [id])

  quantity    Decimal                @db.Decimal(15, 4)  // quantidade reservada
  sourceType  StockReservationSource                     // tipo do documento origem
  sourceId    String                 @db.VarChar(100)    // ID do documento origem

  status      StockReservationStatus @default(ATIVA)
  notes       String?                @db.Text

  reservedAt  DateTime               @default(now())
  releasedAt  DateTime?
  consumedAt  DateTime?

  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([companyId, status])
  @@index([productId, locationId, status])
  @@index([sourceType, sourceId])
  @@map("stock_reservations")
}

// ============================================================================
// SPRINT 3 — CUSTOMIZAÇÃO E ENGENHARIA
// ============================================================================

// ── 3.1 — BOM Customizada por Pedido ──────────────────────────────────────

/// Variação da BOM padrão para uma OP ou Pedido de Venda específico.
/// Quando existir, o release() usa essa BOM em vez da BOM global do produto.
model OrderBomOverride {
  id                  String          @id @default(cuid())
  companyId           String
  company             Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  productionOrderId   String?         @unique   // OP específica
  productionOrder     ProductionOrder? @relation("OpBomOverride", fields: [productionOrderId], references: [id])

  saleOrderId         String?         @unique   // Pedido de Venda específico
  saleOrder           SaleOrder?       @relation("PvBomOverride", fields: [saleOrderId], references: [id])

  originalBomId       String
  originalBom         BillOfMaterial  @relation(fields: [originalBomId], references: [id])

  /// JSON com as customizações: { add: [...], remove: [...], modify: [...] }
  /// add:    [{ productId, quantity, unit, wastagePercent, observations }]
  /// remove: [{ bomItemId }]
  /// modify: [{ bomItemId, quantity?, unit?, wastagePercent?, observations? }]
  customItems         Json

  motivoCustomizacao  String          @db.Text
  aprovadoPorId       String?
  aprovadoPor         User?           @relation("BomOverrideAprovador", fields: [aprovadoPorId], references: [id])

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([companyId])
  @@map("order_bom_overrides")
}

// ── 3.2 — ECO Leve (Engineering Change Order) ─────────────────────────────

enum ECOType {
  BOM                  // Alteração de estrutura de produto
  ROTEIRO              // Alteração de roteiro de fabricação
  ESPECIFICACAO        // Alteração de especificação técnica
  SUBSTITUCAO_MATERIAL // Substituição de material
}

enum ECOStatus {
  RASCUNHO
  APROVADO
  IMPLEMENTADO
  CANCELADO
}

/// Registro formal de mudança de engenharia — não bloqueia a produção,
/// apenas gera rastreabilidade e notificação nos documentos afetados.
model EngineeringChange {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  numero          String    @db.VarChar(50)  // ECO-YYYYMMDD-NNN
  tipo            ECOType
  status          ECOStatus @default(RASCUNHO)

  descricao       String    @db.Text
  motivoTecnico   String    @db.Text
  impactoEstoque  Boolean   @default(false)
  impactoCusto    Boolean   @default(false)

  /// IDs dos documentos afetados (OPs, OSs, Pedidos de Venda)
  documentosAfetados Json   @default("[]")  // [{ type: "ProductionOrder", id: "...", numero: "..." }]

  /// Arquivos anexados (URLs no storage)
  anexos          Json      @default("[]")  // [{ nome, url, tipo }]

  solicitanteId   String?
  solicitante     User?     @relation("EcoSolicitante", fields: [solicitanteId], references: [id])
  aprovadorId     String?
  aprovador       User?     @relation("EcoAprovador", fields: [aprovadorId], references: [id])

  implementadoEm  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId, status])
  @@index([companyId, tipo])
  @@map("engineering_changes")
}

// ── 3.3 — Versões de Orçamento — campos adicionados diretamente no Quotation ──
// versao Int @default(1), versaoAnteriorId String? — já adicionados no model Quotation

// ── 3.4 — Campos Estruturados de Customização ─────────────────────────────

/// Template de campos de customização por categoria/tipo de produto.
/// Ex: "SEMIRREBOQUE" → { comprimento, largura, cor, eixos, ... }
model CustomizationTemplate {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  nome        String   @db.VarChar(200)
  categoria   String   @db.VarChar(100)  // "SEMIRREBOQUE" | "BAU" | "TANQUE" | "PLATAFORMA" | etc.
  descricao   String?  @db.Text

  /// Definição dos campos: [{ key, label, type, required, options?, unit? }]
  /// type: "text" | "number" | "select" | "boolean" | "multiselect"
  campos      Json

  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  saleOrderCustomizations SaleOrderCustomization[]

  @@unique([companyId, categoria])
  @@map("customization_templates")
}

/// Customização específica de um Pedido de Venda.
/// Armazena os valores preenchidos com base no template da categoria do produto.
model SaleOrderCustomization {
  id          String                @id @default(cuid())
  companyId   String
  company     Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  saleOrderId String                @unique
  saleOrder   SaleOrder             @relation(fields: [saleOrderId], references: [id], onDelete: Cascade)

  templateId  String?
  template    CustomizationTemplate? @relation(fields: [templateId], references: [id])

  /// Valores preenchidos: { comprimento: "13.5m", cor: "Branco RAL 9003", eixos: 3, ... }
  campos      Json

  observacoes String?               @db.Text
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@map("sale_order_customizations")
}

// ============================================================================
// SPRINT 4 — INTELIGÊNCIA E DECISÃO
// ============================================================================

// ── 4.2 — MRP Básico (Sugestão de Compra) ─────────────────────────────────

enum MrpSuggestionStatus {
  PENDENTE     // aguardando ação do comprador
  ACEITA       // convertida em Pedido de Compra
  AJUSTADA     // quantidade ajustada manualmente antes de converter
  REJEITADA    // descartada pelo comprador
}

/// Sugestão gerada pelo MRP para cada material com necessidade líquida > 0.
/// O comprador pode aceitar (gera PO automaticamente), ajustar ou rejeitar.
model MrpSuggestion {
  id                 String              @id @default(cuid())
  companyId          String
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)

  rodadaId           String              @db.VarChar(50)  // ID da rodada MRP (agrupa sugestões da mesma execução)
  productId          String
  product            Product             @relation(fields: [productId], references: [id])
  supplierId         String?
  supplier           Person?             @relation("MrpSuggestionSupplier", fields: [supplierId], references: [id])

  necessidadeBruta   Decimal             @db.Decimal(15, 4)
  estoqueDisponivel  Decimal             @db.Decimal(15, 4)
  estoqueReservado   Decimal             @db.Decimal(15, 4)
  necessidadeLiquida Decimal             @db.Decimal(15, 4)
  quantidadeSugerida Decimal             @db.Decimal(15, 4)  // lote econômico ou necessidade líquida
  unit               String              @db.VarChar(20)

  status             MrpSuggestionStatus @default(PENDENTE)
  purchaseOrderId    String?             // PO gerada após aceite

  /// OPs que geraram esta necessidade: [{ opId, opNumero, quantidade }]
  fontes             Json                @default("[]")

  observacoes        String?             @db.Text
  geradoEm           DateTime            @default(now())
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([companyId, status])
  @@index([companyId, rodadaId])
  @@index([productId])
  @@map("mrp_suggestions")
}

// ── 4.4 — Workflow Engine Configurável ────────────────────────────────────

/// Configuração de transições de status por tipo de documento e empresa.
/// Substitui gradualmente os checks hardcoded nos services.
model WorkflowConfig {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  documentType  String   @db.VarChar(100)  // "SaleOrder" | "PurchaseOrder" | "Requisition" | etc.

  /// Array de transições: [{ from, to, label, requiresApproval, lockedFields, freeFields, autoAdvance, condition }]
  transitions   Json

  /// Campos que disparam notificação ao mudar: ["status", "dataEntrega"]
  notifyOnFields Json    @default("[]")

  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, documentType])
  @@map("workflow_configs")
}

// ── IA FISCAL — Fase 1 ────────────────────────────────────────────────────

/// Cada decisão de classificação fiscal tomada pela IA.
/// Rastreabilidade completa: o que a IA decidiu, por quê, com qual confiança.
model FiscalBrainDecision {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  documentType    String   @db.VarChar(50)   // "NFe" | "NFSe" | "CTe" | "NFCe"
  documentId      String                      // ID do documento no ERP

  /// Parâmetros usados para classificar (snapshot do contexto)
  contexto        Json

  /// Classificação sugerida pela IA
  cfop            String?  @db.VarChar(10)
  cstIcms         String?  @db.VarChar(10)
  cstPis          String?  @db.VarChar(10)
  cstCofins       String?  @db.VarChar(10)
  aliquotaIcms    Decimal? @db.Decimal(8, 4)
  aliquotaPis     Decimal? @db.Decimal(8, 4)
  aliquotaCofins  Decimal? @db.Decimal(8, 4)
  aliquotaIpi     Decimal? @db.Decimal(8, 4)
  beneficioFiscal String?  @db.VarChar(200)

  /// Fundamentação legal retornada pela IA
  fundamentoLegal Json     @default("[]")   // string[]
  raciocinio      String   @db.Text
  alternativas    Json     @default("[]")   // top-3 alternativas descartadas
  alertas         Json     @default("[]")   // avisos de atenção

  /// Confiança 0-100; abaixo do threshold vai para fila de exceções
  confianca       Int

  /// true = IA aplicou automaticamente; false = foi para fila de revisão humana
  autoAplicado    Boolean  @default(false)

  /// Preenchido quando humano revisou e corrigiu
  revisadoPor     String?
  correcao        Json?    // { cfop, cstIcms, ... } — o que foi corrigido
  revisadoEm      DateTime?

  createdAt       DateTime @default(now())

  excecao         ExcecaoFiscal?

  @@index([companyId, documentId])
  @@index([companyId, autoAplicado, createdAt])
  @@map("fiscal_brain_decisions")
}

/// Fila de exceções: documentos que a IA não classificou com confiança suficiente.
/// O usuário revisa, corrige e alimenta o feedback loop.
model ExcecaoFiscal {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  decisionId      String        @unique
  decision        FiscalBrainDecision @relation(fields: [decisionId], references: [id])

  documentType    String        @db.VarChar(50)
  documentId      String

  /// Por que foi para a fila: "Confiança 74% — abaixo do threshold 92%"
  motivo          String        @db.Text

  status          ExcecaoStatus @default(PENDENTE)

  resolvidoPor    String?
  resolucao       Json?         // classificação final aprovada/corrigida pelo humano
  resolvidoEm     DateTime?

  createdAt       DateTime      @default(now())

  @@index([companyId, status])
  @@index([companyId, documentId])
  @@map("excecoes_fiscais")
}

enum ExcecaoStatus {
  PENDENTE
  RESOLVIDA
  IGNORADA
}

/// Base de conhecimento fiscal — trechos de legislação usados como contexto para a IA.
/// Pesquisados por UF + tipo + palavras-chave antes de cada classificação.
model LegislacaoItem {
  id              String    @id @default(cuid())
  tipo            String    @db.VarChar(30)   // "RICMS" | "RIPI" | "LC214" | "CONVENIO" | "IN_RFB" | "CARF"
  uf              String?   @db.VarChar(2)    // null = federal/nacional
  numero          String    @db.VarChar(100)  // "LC 87/1996" | "RICMS-SP/2000"
  artigo          String?   @db.VarChar(100)  // "Art. 52 §1"
  assunto         String    @db.VarChar(500)  // para busca: "ICMS interestadual produto industrializado"
  texto           String    @db.Text          // texto legal completo do trecho
  vigenciaInicio  DateTime
  vigenciaFim     DateTime?                   // null = vigente
  ativo           Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tipo, uf])
  @@index([ativo, vigenciaFim])
  @@map("legislacao_items")
}

/// Mensagens do chat FiscalBrain — histórico de conversas com o consultor fiscal IA.
model FiscalBrainChatMessage {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  role        String   @db.VarChar(20)
  content     String   @db.Text
  toolsUsed   Json?
  createdAt   DateTime @default(now())

  @@index([companyId, createdAt])
  @@map("fiscal_brain_chat_messages")
}
