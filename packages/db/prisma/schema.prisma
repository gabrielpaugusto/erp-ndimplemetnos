  INSUMO_PRODUCAO        // Controla estoque → GGF
  EMBALAGEM              // Controla estoque
  MATERIAL_USO_CONSUMO   // Despesa direta → sem crédito fiscal até 2033
  GGF                    // Controla estoque → gasto geral de fabricação (custo indireto)
  IMOBILIZADO            // Controla ativo → CIAP 1/48 ICMS
  SERVICO                // Sem estoque → despesa de serviços
  FRETE                  // CT-e: ICMS+PIS/COFINS crédito se FOB; sem crédito se CIF
  SERVICO_TOMADO         // NFS-e tomada: PIS/COFINS crédito (Lucro Real); ISS/retenções conforme regra
  PRODUTO_INDUSTRIALIZADO // saída: produto fabricado pela empresa (CFOP 5101/6101)
  SERVICO_EMITIDO         // saída: NFS-e emitida pela empresa (CFOP 5933/6933)
  DEVOLUCAO_COMPRA        // saída: devolução de mercadoria comprada (CFOP 5201/6201)
}

// Tipo fiscal/comercial do fornecedor — determina IPI, ICMS e créditos na entrada
enum TipoFornecedor {
  INDUSTRIA                // Industrial — destaca ICMS + IPI
  ATACADISTA_EQUIPARADO    // Atacadista equiparado a indústria (RIPI art. 9°/11) — destaca ICMS + IPI
  COMERCIO                 // Comércio não-Simples — destaca ICMS, sem IPI
  SIMPLES_NACIONAL         // Optante Simples — crédito ICMS via pCredSN; PIS/COFINS crédito pleno
  MEI                      // MEI — sem crédito ICMS/IPI; PIS/COFINS crédito pleno
  IMPORTADOR               // Importador direto — ICMS + IPI na importação
  PESSOA_FISICA            // PF — sem destaque de impostos
}

// Tipo do destinatário — determina CFOP interestadual e DIFAL nas saídas
