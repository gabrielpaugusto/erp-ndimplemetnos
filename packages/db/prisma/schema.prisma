  ambiente        String   @db.VarChar(1)    // "1" prod / "2" homo
  nsuEnviado      String?  @db.VarChar(15)
  nsuRetornado    String?  @db.VarChar(15)
  cStat           String?  @db.VarChar(3)
  xMotivo         String?  @db.VarChar(255)
  totalDocs       Int?
