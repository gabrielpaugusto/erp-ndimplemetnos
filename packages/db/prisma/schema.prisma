  dataCompetencia    DateTime?

  // Status
  status             NfseStatus @default(RECEBIDA)
  xmlContent         String?    @db.Text

  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@map("nfse_recebidas")
}

model SefazAuditLog {
