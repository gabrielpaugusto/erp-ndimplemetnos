// ============================================================================
// GRUPOS E SUBGRUPOS DE MATERIAIS
// ============================================================================

model ProductGroup {
  id          String           @id @default(cuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  code        String           @db.VarChar(2)   // GG: 01-10
  name        String           @db.VarChar(60)
  description String?          @db.VarChar(200)
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  subgroups   ProductSubgroup[]
  products    Product[]

  @@unique([companyId, code])
  @@map("product_groups")
}

model ProductSubgroup {
  id          String        @id @default(cuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id])
  groupId     String
  group       ProductGroup  @relation(fields: [groupId], references: [id])
  code        String        @db.VarChar(2)   // SS: 01-99
  name        String        @db.VarChar(60)
  description String?       @db.VarChar(200)
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  products    Product[]

  @@unique([groupId, code])
  @@map("product_subgroups")
}

// ============================================================================
// PRODUTOS E SERVIÇOS
// ============================================================================

model Product {
  id                  String        @id @default(cuid())
  companyId           String
  company             Company       @relation(fields: [companyId], references: [id])

  // Identificação
  code                String        @db.VarChar(50)  // código interno
  barcode             String?       @db.VarChar(14)  // EAN/GTIN
  description         String        @db.VarChar(500)
  descriptionShort    String?       @db.VarChar(120) // descrição para NF-e (max 120 chars)

  // Classificação
  type                ProductType
  origin              ProductOrigin @default(NACIONAL_0)
  unit                UnitType      @default(UN)

  // Grupo e Subgrupo (cascata)
  groupId             String?
  group               ProductGroup?    @relation(fields: [groupId], references: [id])
  subgroupId          String?
  subgroup            ProductSubgroup? @relation(fields: [subgroupId], references: [id])

  // NCM / Fiscal
  ncmId               String?
  ncm                 Ncm?          @relation(fields: [ncmId], references: [id])
  cestCode            String?       @db.VarChar(7)   // CEST (substituição tributária)

  // Preços
  precoCusto          Decimal?      @db.Decimal(15, 4)
  precoVenda          Decimal?      @db.Decimal(15, 4)
  margemLucro         Decimal?      @db.Decimal(5, 2)

  // Estoque
  estoqueMinimo       Decimal?      @db.Decimal(15, 4)
  estoqueMaximo       Decimal?      @db.Decimal(15, 4)
  estoqueAtual        Decimal       @default(0) @db.Decimal(15, 4)
  localizacao         String?       @db.VarChar(50) // localização no almoxarifado

  // Controle de estoque
  controlaEstoque     Boolean       @default(true)  // false = compra vira despesa imediata
  loteEconomico       Decimal?      @db.Decimal(15, 4)
  leadTimeDias        Int?
  custoUltimo         Decimal?      @db.Decimal(15, 4)
  custoMedio          Decimal?      @db.Decimal(15, 4)
  dataUltimaMovimentacao DateTime?

  // Flags de finalidade (validadas na saída)
  usoProducaoOp       Boolean       @default(false) // saída por Ordem de Produção
  usoGgf              Boolean       @default(false) // saída por Requisição GGF
  usoOficinaOs        Boolean       @default(false) // saída por Ordem de Serviço
  usoRevenda          Boolean       @default(false) // saída por Pedido de Venda
  usoConsumo          Boolean       @default(false) // saída por Requisição de Uso e Consumo

  // Peso/Dimensões (necessários para NF-e de transporte)
  pesoLiquido         Decimal?      @db.Decimal(10, 4) // kg
  pesoBruto           Decimal?      @db.Decimal(10, 4) // kg
  comprimento         Decimal?      @db.Decimal(10, 2) // cm
  largura             Decimal?      @db.Decimal(10, 2) // cm
  altura              Decimal?      @db.Decimal(10, 2) // cm

  // Centro de custo padrão
  costCenterCode      CostCenterCode?

  // Destinação fiscal padrão (A4 — define o tratamento TES: CFOP, CST, crédito)
  destinacaoFiscal    ItemDestinacao?  // MATERIA_PRIMA | PRODUTO_REVENDA | PRODUTO_INDUSTRIALIZADO | IMOBILIZADO …

  // Observações
  observacoes         String?       @db.Text
  imagemUrl           String?       @db.VarChar(500)

  active              Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // CRM/Sales relations
  quotationItems      QuotationItem[]
  saleOrderItems      SaleOrderItem[]

  // PCP / Produção relations
  boms                    BillOfMaterial[]
  routings                ProductionRouting[]
  productionOrders        ProductionOrder[]
  bomItems                BomItem[]
  productionOrderItems    ProductionOrderItem[]

  // Oficina / Requisições
  serviceOrderItems       ServiceOrderItem[]
  requisitionItems        RequisitionItem[]

  // Fiscal (Sprint 7)
  nfeItems                NFeItem[]

  // Compras / Estoque (Sprint 9)
  purchaseRequestItems    PurchaseRequestItem[]
  supplierQuotationItems  SupplierQuotationItem[]
  purchaseOrderItems      PurchaseOrderItem[]
  stockBalances           StockBalance[]
  stockMovements          StockMovement[]
  inventoryItems          InventoryItem[]

  // Fluxo de Compras Integrado
  productSuppliers        ProductSupplier[]
  nfeInboxItems           NFeInboxItem[]
  purchaseReceiptItems    PurchaseReceiptItem[]

  // Auditoria NCM
  ncmAuditorias           NcmAuditoria[]

  // Sprint 2 — Reservas de estoque
  stockReservations       StockReservation[]

  // Sprint 4 — MRP
  mrpSuggestions          MrpSuggestion[]

  @@unique([companyId, code])
  @@index([description])
  @@index([type])
  @@map("products")
}

// ============================================================================
// TABELA DE MUNICÍPIOS IBGE
// ============================================================================

model MunicipioIbge {
  id        String @id @default(cuid())
  codigoUf  String @db.VarChar(2)
  uf        String @db.VarChar(2)
  codigo    String @unique @db.VarChar(7)  // código IBGE 7 dígitos
  nome      String @db.VarChar(100)

  @@index([uf])
  @@map("municipios_ibge")
}

// ============================================================================
// CRM — LEADS E OPORTUNIDADES
// ============================================================================

model Lead {
  id              String      @id @default(cuid())
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id])

  // Cliente
  personId        String?
  person          Person?     @relation(fields: [personId], references: [id])

  // Lead info (quando pessoa ainda não cadastrada)
  contactName     String?     @db.VarChar(200)
  contactEmail    String?     @db.VarChar(200)
  contactPhone    String?     @db.VarChar(20)
  companyName     String?     @db.VarChar(200)

  // Pipeline
  title           String      @db.VarChar(300)
  description     String?     @db.Text
  status          LeadStatus  @default(NOVO)
  source          LeadSource  @default(OUTROS)
  valorEstimado   Decimal?    @db.Decimal(15, 2)
  probabilidade   Int?        @default(50) // 0-100%

  // Responsável
  vendedorId      String?
  vendedor        User?       @relation("LeadVendedor", fields: [vendedorId], references: [id])

  // Datas
  dataPrevisaoFechamento DateTime?
  dataFechamento  DateTime?
  motivoPerda     String?     @db.VarChar(300)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  activities      LeadActivity[]
  quotations      Quotation[]

  @@index([companyId, status])
  @@index([vendedorId])
  @@map("leads")
}

model LeadActivity {
  id          String       @id @default(cuid())
  leadId      String
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation("ActivityUser", fields: [userId], references: [id])
  type        ActivityType
  title       String       @db.VarChar(300)
  description String?      @db.Text
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())

  @@index([leadId, createdAt])
  @@map("lead_activities")
}

// ============================================================================
// ORÇAMENTOS / PROPOSTAS
// ============================================================================

model Quotation {
  id              String          @id @default(cuid())
  companyId       String
  company         Company         @relation(fields: [companyId], references: [id])
  leadId          String?
  lead            Lead?           @relation(fields: [leadId], references: [id])
  personId        String
  person          Person          @relation(fields: [personId], references: [id])

  numero          Int
  status          QuotationStatus @default(RASCUNHO)
  saleType        SaleType        @default(ESTOQUE_PROPRIO)

  // Valores
  subtotal        Decimal         @db.Decimal(15, 2) @default(0)
  desconto        Decimal         @db.Decimal(15, 2) @default(0)
  totalFrete      Decimal         @db.Decimal(15, 2) @default(0)
  total           Decimal         @db.Decimal(15, 2) @default(0)

  // Condições
  condicaoPagamento String?       @db.VarChar(100)
  validadeOrcamento DateTime?
  prazoEntrega    String?         @db.VarChar(100)
  observacoes     String?         @db.Text

  // Vendedor e comissão
  vendedorId      String?
  vendedor        User?           @relation("QuotationVendedor", fields: [vendedorId], references: [id])
  comissaoPercent Decimal?        @db.Decimal(5, 2)

  // Sprint 3.3 — Versões de Orçamento
  versao            Int       @default(1)
  versaoAnteriorId  String?
  versaoAnterior    Quotation? @relation("QuotationVersions", fields: [versaoAnteriorId], references: [id])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  items           QuotationItem[]
  saleOrder       SaleOrder?
  versoes         Quotation[]     @relation("QuotationVersions")  // Sprint 3.3

  @@unique([companyId, numero])
  @@index([personId])
  @@map("quotations")
}

model QuotationItem {
  id            String    @id @default(cuid())
  quotationId   String
  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product?  @relation(fields: [productId], references: [id])
  sequencia     Int       @default(1)
  itemType      SaleType  @default(ESTOQUE_PROPRIO)
  quantidade    Decimal   @db.Decimal(15, 4)
  precoUnitario Decimal   @db.Decimal(15, 4)
  desconto      Decimal   @db.Decimal(15, 2) @default(0)
  total         Decimal   @db.Decimal(15, 2) @default(0)

  // Fiscal (preenchido na conversão / faturamento)
  ncmCode       String?   @db.VarChar(10)

  // Para itens de serviço / F&I (sem produto vinculado)
  descricaoLivre String?  @db.VarChar(300)

  observacoes   String?   @db.VarChar(300)

  @@map("quotation_items")
}

// ============================================================================
// PEDIDOS DE VENDA
// ============================================================================

model SaleOrder {
  id              String      @id @default(cuid())
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id])
  quotationId     String?     @unique
  quotation       Quotation?  @relation(fields: [quotationId], references: [id])
  personId        String
  person          Person      @relation(fields: [personId], references: [id])

  numero          Int
  status          SaleStatus  @default(RASCUNHO)
  saleType        SaleType    @default(ESTOQUE_PROPRIO)
  finalidadeOperacao FinalidadeOperacao @default(REVENDA)

  // Valores
  subtotal        Decimal     @db.Decimal(15, 2) @default(0)
  desconto        Decimal     @db.Decimal(15, 2) @default(0)
  totalFrete      Decimal     @db.Decimal(15, 2) @default(0)
  total           Decimal     @db.Decimal(15, 2) @default(0)

  // Condições
  condicaoPagamento String?   @db.VarChar(100)
  prazoEntrega    String?     @db.VarChar(100)
  observacoes     String?     @db.Text
  motivoAlteracao String?     @db.Text  // Motivo de alterações pós-aprovação

  // Vendedor e comissão
  vendedorId      String?
  vendedor        User?       @relation("SaleOrderVendedor", fields: [vendedorId], references: [id])
  comissaoPercent Decimal?    @db.Decimal(5, 2)
  comissaoValor   Decimal?    @db.Decimal(15, 2)

  // Venda Direta — dados específicos
  fabricanteId    String?     // Person do fabricante/fábrica (quando VENDA_DIRETA)
  fabricante      Person?     @relation("SaleOrderFabricante", fields: [fabricanteId], references: [id])
  notaFabrica     String?     @db.VarChar(50)  // número NF-e da fábrica

  // Centro de custo
  costCenterCode  CostCenterCode?

  // Datas
  dataAprovacao   DateTime?
  dataFaturamento DateTime?
  dataEntrega     DateTime?
  dataCancelamento DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  items               SaleOrderItem[]
  financings          Financing[]
  consortiumQuotas    ConsortiumQuota[]
  insurancePolicies   InsurancePolicy[]
  productionOrders    ProductionOrder[]

  // Fiscal (Sprint 7)
  nfeDocuments        NFeDocument[]

  // Financeiro (Sprint 8)
  financialMovements  FinancialMovement[]

  // Estoque (Sprint 9)
  stockMovements      StockMovement[]

  // Portal (Sprint 10)
  portalDocuments     PortalDocument[]

  // Sprint 3 — Customização
  bomOverride         OrderBomOverride?        @relation("PvBomOverride")
  customization       SaleOrderCustomization?

  @@unique([companyId, numero])
  @@index([personId])
  @@index([status])
  @@map("sale_orders")
}

model SaleOrderItem {
  id              String    @id @default(cuid())
  saleOrderId     String
  saleOrder       SaleOrder @relation(fields: [saleOrderId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id])
  sequencia       Int       @default(1)
  itemType        SaleType  @default(ESTOQUE_PROPRIO)
  quantidade      Decimal   @db.Decimal(15, 4)
  precoUnitario   Decimal   @db.Decimal(15, 4)
  desconto        Decimal   @db.Decimal(15, 2) @default(0)
  total           Decimal   @db.Decimal(15, 2) @default(0)

  // Fiscal (preenchido no faturamento)
  ncmCode         String?   @db.VarChar(10)

  // Para itens de serviço / F&I (sem produto vinculado)
  descricaoLivre  String?   @db.VarChar(300)

  observacoes     String?   @db.VarChar(300)

  @@map("sale_order_items")
}

// ============================================================================
// F&I — FINANCIAMENTO, CONSÓRCIO, SEGURO
// ============================================================================

model Financing {
  id              String           @id @default(cuid())
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  saleOrderId     String?
  saleOrder       SaleOrder?       @relation(fields: [saleOrderId], references: [id])
  personId        String           // Cliente
  person          Person           @relation(fields: [personId], references: [id])

  // Tipo e status
  type            FinancingType
  status          FinancingStatus  @default(SIMULACAO)
  numero          String?          @db.VarChar(50) // número do contrato

  // Instituição financeira
  financeiraId    String?          // Person da financeira/banco
  financeira      Person?          @relation("FinancingFinanceira", fields: [financeiraId], references: [id])

  // Valores
  valorBem        Decimal          @db.Decimal(15, 2) // valor do implemento
  valorEntrada    Decimal?         @db.Decimal(15, 2)
  valorFinanciado Decimal          @db.Decimal(15, 2)
  taxaJuros       Decimal?         @db.Decimal(8, 4)  // % ao mês
  parcelas        Int?             // número de parcelas
  valorParcela    Decimal?         @db.Decimal(15, 2)

  // FINAME específico
  codigoFiname    String?          @db.VarChar(20) // código do produto FINAME
  linhaCredito    String?          @db.VarChar(100) // ex: "FINAME BK", "FINAME Agrícola"
  carencia        Int?             // meses de carência

  // Comissão da concessionária
  comissaoPercent Decimal?         @db.Decimal(5, 2)
  comissaoValor   Decimal?         @db.Decimal(15, 2)

  // Datas
  dataSimulacao   DateTime?
  dataProposta    DateTime?
  dataAprovacao   DateTime?
  dataContratacao DateTime?
  dataLiberacao   DateTime?

  observacoes     String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([companyId, status])
  @@index([personId])
  @@map("financings")
}

model ConsortiumQuota {
  id                  String           @id @default(cuid())
  companyId           String
  company             Company          @relation(fields: [companyId], references: [id])
  personId            String           // Cotista/cliente
  person              Person           @relation(fields: [personId], references: [id])

  // Administradora
  administradoraId    String?          // Person da administradora
  administradora      Person?          @relation("ConsortiumAdministradora", fields: [administradoraId], references: [id])

  // Dados da cota
  grupo               String           @db.VarChar(20)
  cota                String           @db.VarChar(20)
  status              ConsortiumStatus @default(ATIVO)

  // Valores
  valorCredito        Decimal          @db.Decimal(15, 2)
  valorPago           Decimal          @db.Decimal(15, 2) @default(0)
  saldoDevedor        Decimal          @db.Decimal(15, 2) @default(0)
  parcelasMensais     Int?
  valorParcelaMensal  Decimal?         @db.Decimal(15, 2)
  parcelasPagas       Int              @default(0)

  // Contemplação
  dataContemplacao    DateTime?
  tipoContemplacao    String?          @db.VarChar(50) // "LANCE", "SORTEIO"
  valorLance          Decimal?         @db.Decimal(15, 2)

  // Vínculo com venda
  saleOrderId         String?
  saleOrder           SaleOrder?       @relation(fields: [saleOrderId], references: [id])

  // Comissão da concessionária
  comissaoPercent     Decimal?         @db.Decimal(5, 2)
  comissaoValor       Decimal?         @db.Decimal(15, 2)

  // Datas
  dataAdesao          DateTime?
  dataEncerramento    DateTime?

  observacoes         String?          @db.Text
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  // Relations
  payments            ConsortiumPayment[]

  @@index([companyId, status])
  @@index([personId])
  @@map("consortium_quotas")
}

model ConsortiumPayment {
  id              String          @id @default(cuid())
  quotaId         String
  quota           ConsortiumQuota @relation(fields: [quotaId], references: [id], onDelete: Cascade)
  numeroParcela   Int
  dataVencimento  DateTime
  dataPagamento   DateTime?
  valor           Decimal         @db.Decimal(15, 2)
  valorPago       Decimal?        @db.Decimal(15, 2)
  status          String          @db.VarChar(20) // PENDENTE, PAGO, ATRASADO
  createdAt       DateTime        @default(now())

  @@index([quotaId])
  @@map("consortium_payments")
}

model InsurancePolicy {
  id              String          @id @default(cuid())
  companyId       String
  company         Company         @relation(fields: [companyId], references: [id])
  personId        String          // Segurado
  person          Person          @relation(fields: [personId], references: [id])

  // Seguradora
  seguradoraId    String?         // Person da seguradora
  seguradora      Person?         @relation("InsuranceSeguradora", fields: [seguradoraId], references: [id])

  // Dados da apólice
  type            InsuranceType
  status          InsuranceStatus @default(COTACAO)
  numeroApolice   String?         @db.VarChar(50)
  numeroProposta  String?         @db.VarChar(50)

  // Bem segurado
  descricaoBem    String          @db.VarChar(300)
  anoFabricacao   Int?
  chassi          String?         @db.VarChar(30)
  placa           String?         @db.VarChar(10)

  // Valores
  valorBem        Decimal         @db.Decimal(15, 2)
  premio          Decimal?        @db.Decimal(15, 2) // valor do prêmio
  franquia        Decimal?        @db.Decimal(15, 2)
  importanciaSegurada Decimal?    @db.Decimal(15, 2)

  // Vigência
  dataInicio      DateTime?
  dataFim         DateTime?
  dataRenovacao   DateTime?       // alerta de renovação

  // Vínculo com venda
  saleOrderId     String?
  saleOrder       SaleOrder?      @relation(fields: [saleOrderId], references: [id])

  // Comissão
  comissaoPercent Decimal?        @db.Decimal(5, 2)
  comissaoValor   Decimal?        @db.Decimal(15, 2)

  observacoes     String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([companyId, status])
  @@index([personId])
  @@map("insurance_policies")
}

// ============================================================================
// PCP — CENTROS DE TRABALHO, BOM, ROTEIROS, ORDENS DE PRODUÇÃO
// ============================================================================

model WorkCenter {
  id              String         @id @default(cuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  code            String         @db.VarChar(50)
  name            String         @db.VarChar(200)
  type            WorkCenterType
  description     String?        @db.VarChar(500)
  capacidadeHora  Float          // capacidade horas/dia
  custoHora       Float          // custo por hora
  active          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  routingSteps    RoutingStep[]
  pointings       ProductionPointing[]

  @@unique([companyId, code])
  @@map("work_centers")
}

model BillOfMaterial {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  version     Int      @default(1)
  description String?  @db.VarChar(500)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  items           BomItem[]
  bomOverrides    OrderBomOverride[]  // Sprint 3.1

  @@unique([productId, version])
  @@map("bills_of_material")
}

model BomItem {
  id             String          @id @default(cuid())
  bomId          String
  bom            BillOfMaterial  @relation(fields: [bomId], references: [id], onDelete: Cascade)
  productId      String
  product        Product         @relation(fields: [productId], references: [id])
  quantity       Float
  unit           String          @db.VarChar(20)
  wastagePercent Float           @default(0) // % perda
  observations   String?         @db.VarChar(500)

  @@map("bom_items")
}

model ProductionRouting {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  version     Int      @default(1)
  description String?  @db.VarChar(500)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  steps            RoutingStep[]
  productionOrders ProductionOrder[]

  @@unique([productId, version])
  @@map("production_routings")
}

model RoutingStep {
  id            String            @id @default(cuid())
  routingId     String
  routing       ProductionRouting @relation(fields: [routingId], references: [id], onDelete: Cascade)
  stepNumber    Int
  workCenterId  String
  workCenter    WorkCenter        @relation(fields: [workCenterId], references: [id])
  description   String            @db.VarChar(500)
  tempoSetup    Float             // minutos
  tempoExecucao Float             // minutos por unidade
  tempoEspera   Float             @default(0) // minutos de espera
  instructions  String?           @db.Text

  apontamentos  Apontamento[]

  @@unique([routingId, stepNumber])
  @@map("routing_steps")
}

model ProductionOrder {
  id                  String                @id @default(cuid())
  companyId           String
  company             Company               @relation(fields: [companyId], references: [id])
  numero              String                @db.VarChar(50)
  productId           String
  product             Product               @relation(fields: [productId], references: [id])
  routingId           String?
  routing             ProductionRouting?    @relation(fields: [routingId], references: [id])
  saleOrderId         String?
  saleOrder           SaleOrder?            @relation(fields: [saleOrderId], references: [id])
  strategy            ProductionStrategy
  type                ProductionOrderType   @default(NORMAL)
  status              ProductionOrderStatus @default(PLANEJADA)
  quantity            Float
  quantityProduced    Float                 @default(0)
  dataInicioPrevista  DateTime
  dataFimPrevista     DateTime
  dataInicioReal      DateTime?
  dataFimReal         DateTime?
  priority            Int                   @default(5) // 1=highest
  observations        String?               @db.Text
  bomSnapshot         Json?                 // Snapshot completo da BOM no momento da liberação
  bomVersion          Int?                  // Versão da BOM utilizada
  motivoAlteracao     String?               @db.Text  // Motivo de alterações pós-criação
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  // Relations
  items               ProductionOrderItem[]
  pointings           ProductionPointing[]
  apontamentos        Apontamento[]

  // Oficina / Calderaria / Requisições
  calderariaOrders    CalderariaOrder[]
  requisitions        Requisition[]

  // Estoque (Sprint 9)
  stockMovements      StockMovement[]

  // Sprint 3 — BOM customizada
  bomOverride         OrderBomOverride?  @relation("OpBomOverride")

  @@unique([companyId, numero])
  @@map("production_orders")
}

model ProductionOrderItem {
  id                String          @id @default(cuid())
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  productId         String
  product           Product         @relation(fields: [productId], references: [id])
  quantityRequired  Float
  quantityConsumed  Float           @default(0)
  unit              String          @db.VarChar(20)

  @@map("production_order_items")
}

model ProductionPointing {
  id                String          @id @default(cuid())
  companyId         String
  company           Company         @relation(fields: [companyId], references: [id])
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id])
  workCenterId      String
  workCenter        WorkCenter      @relation(fields: [workCenterId], references: [id])
  userId            String
  user              User            @relation(fields: [userId], references: [id])
  type              PointingType
  dataInicio        DateTime
  dataFim           DateTime?
  quantityProduced  Float           @default(0)
  quantityRejected  Float           @default(0)
  observations      String?         @db.Text
  motivoParada      String?         @db.VarChar(300) // para tipo PARADA
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([companyId, productionOrderId])
  @@map("production_pointings")
}

// ============================================================================
// OFICINA — ORDENS DE SERVIÇO
// ============================================================================

model ServiceOrder {
  id                String               @id @default(cuid())
  companyId         String
  company           Company              @relation(fields: [companyId], references: [id])
  numero            String               @db.VarChar(50)
  personId          String
  person            Person               @relation(fields: [personId], references: [id])
  type              ServiceOrderType
  status            ServiceOrderStatus   @default(ABERTA)
  priority          ServiceOrderPriority @default(NORMAL)

  // Veículo
  veiculoDescricao  String               @db.VarChar(500)
  veiculoPlaca      String?              @db.VarChar(10)
  veiculoChassi     String?              @db.VarChar(30)
  veiculoKm         Int?

  // Defeito / Diagnóstico / Solução
  defeitoRelatado   String               @db.Text
  diagnostico       String?              @db.Text
  solucao           String?              @db.Text

  // Datas
  dataEntrada       DateTime
  dataPrevisao      DateTime?
  dataConclusao     DateTime?
  dataEntrega       DateTime?

  // Valores
  valorPecas        Float                @default(0)
  valorMaoDeObra    Float                @default(0)
  valorTotal        Float                @default(0)

  // Responsável (técnico atribuído)
  responsavelId     String?
  responsavel       User?                @relation("ServiceOrderResponsavel", fields: [responsavelId], references: [id])

  observations      String?              @db.Text

  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  // Relations
  items             ServiceOrderItem[]
  requisitions      Requisition[]
  calderariaOrders  CalderariaOrder[]
  etapasOs          EtapaOS[]
  apontamentos      Apontamento[]

  // Fiscal (Sprint 7)
  nfeDocuments      NFeDocument[]

  // Portal (Sprint 10)
  portalDocuments   PortalDocument[]

  @@unique([companyId, numero])
  @@index([personId])
  @@index([status])
  @@map("service_orders")
}

model ServiceOrderItem {
  id              String        @id @default(cuid())
  serviceOrderId  String
  serviceOrder    ServiceOrder  @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product?      @relation(fields: [productId], references: [id])
  description     String        @db.VarChar(500)
  quantity        Float
  unitPrice       Float
  totalPrice      Float
  type            String        @db.VarChar(20) // PECA, SERVICO, TERCEIRO

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("service_order_items")
}

// ============================================================================
// CALDERARIA — ORDENS DE SERVIÇO DE CALDERARIA
// ============================================================================

model CalderariaOrder {
  id                      String                @id @default(cuid())
  companyId               String
  company                 Company               @relation(fields: [companyId], references: [id])
  numero                  String                @db.VarChar(50)
  serviceOrderId          String?
  serviceOrder            ServiceOrder?         @relation(fields: [serviceOrderId], references: [id])
  productionOrderId       String?
  productionOrder         ProductionOrder?      @relation(fields: [productionOrderId], references: [id])

  serviceType             CalderariaServiceType
  description             String                @db.VarChar(500)
  materialDescription     String?               @db.VarChar(500)

  status                  ServiceOrderStatus    @default(ABERTA)

  // Tempos
  dataInicio              DateTime?
  dataFim                 DateTime?
  tempoEstimado           Float?                // horas
  tempoReal               Float?                // horas

  // Responsável (soldador/operador)
  responsavelId           String?
  responsavel             User?                 @relation("CalderariaOrderResponsavel", fields: [responsavelId], references: [id])

  observations            String?               @db.Text
  especificacoesTecnicas  String?               @db.Text // espessura, tipo material, tipo solda etc.

  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  // Relations
  requisitions            Requisition[]
  etapasCalderaria        EtapaCalderaria[]
  apontamentos            Apontamento[]

  @@unique([companyId, numero])
  @@index([serviceOrderId])
  @@index([status])
  @@map("calderaria_orders")
}

// ============================================================================
// REQUISIÇÕES DE MATERIAIS (INTERNA OU COMPRA)
// ============================================================================

model Requisition {
  id                  String            @id @default(cuid())
  companyId           String
  company             Company           @relation(fields: [companyId], references: [id])
  numero              String            @db.VarChar(50)
  type                RequisitionType
  status              RequisitionStatus @default(RASCUNHO)

  // Solicitante / Aprovador
  solicitanteId       String
  solicitante         User              @relation("RequisitionSolicitante", fields: [solicitanteId], references: [id])
  aprovadorId         String?
  aprovador           User?             @relation("RequisitionAprovador", fields: [aprovadorId], references: [id])

  // Vínculos opcionais
  serviceOrderId      String?
  serviceOrder        ServiceOrder?     @relation(fields: [serviceOrderId], references: [id])
  calderariaOrderId   String?
  calderariaOrder     CalderariaOrder?  @relation(fields: [calderariaOrderId], references: [id])
  productionOrderId   String?
  productionOrder     ProductionOrder?  @relation(fields: [productionOrderId], references: [id])

  // Datas
  dataAprovacao       DateTime?
  dataEntrega         DateTime?

  observations        String?           @db.Text
  justificativa       String?           @db.Text
  motivoAlteracao     String?           @db.Text  // Motivo de alterações pós-aprovação

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  // Relations
  items               RequisitionItem[]

  // Estoque (Sprint 9)
  stockMovements      StockMovement[]

  @@unique([companyId, numero])
  @@index([solicitanteId])
  @@index([status])
  @@map("requisitions")
}

model RequisitionItem {
  id                String             @id @default(cuid())
  requisitionId     String
  requisition       Requisition        @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  productId         String
  product           Product            @relation(fields: [productId], references: [id])
  quantityRequested Float
  quantityApproved  Float?
  quantityDelivered Float              @default(0)
  unit              String             @db.VarChar(20)

  // Sprint 2.2 — Aprovação parcial por item
  statusAprovacao   ItemApprovalStatus @default(PENDENTE)
  motivoRejeicao    String?            @db.Text

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("requisition_items")
}

// ============================================================================
// SPRINT 7 — MÓDULO FISCAL (REFORMA TRIBUTÁRIA EC 132/2023)
// ============================================================================

enum NFeStatus {
  RASCUNHO
  VALIDADA
  ASSINADA
  TRANSMITIDA
  AUTORIZADA
  CANCELADA
  DENEGADA
  INUTILIZADA
  ESCRITURADA
}

enum NFeType {
  ENTRADA
  SAIDA
}

enum NFeFinality {
  NORMAL
  COMPLEMENTAR
  AJUSTE
  DEVOLUCAO
}

enum NFeOperation {
  VENDA
  COMPRA
  TRANSFERENCIA
  DEVOLUCAO_VENDA
  DEVOLUCAO_COMPRA
  REMESSA
  RETORNO
  BONIFICACAO
  CONSIGNACAO
  INDUSTRIALIZACAO
}

enum TaxDocumentType {
  NFE
  NFCE
  NFSE
  CTE
  MDFE
}

enum FiscalEntryType {
  DEBITO
  CREDITO
}

enum FiscalBookType {
  ENTRADA
  SAIDA
  APURACAO_ICMS
  APURACAO_IPI
  APURACAO_PIS
  APURACAO_COFINS
}

// ============================================================================
// NF-e — NOTA FISCAL ELETRÔNICA
// ============================================================================

model NFeDocument {
  id                      String          @id @default(cuid())
  companyId               String
  company                 Company         @relation(fields: [companyId], references: [id])

  // Identificação
  numero                  Int?
  serie                   Int             @default(1)
  chaveAcesso             String?         @unique @db.VarChar(44)
  type                    NFeType
  finality                NFeFinality     @default(NORMAL)
  operation               NFeOperation
  status                  NFeStatus       @default(RASCUNHO)
  documentType            TaxDocumentType @default(NFE)

  // Emitente / Destinatário
  personId                String
  person                  Person          @relation(fields: [personId], references: [id])

  // Vínculos opcionais
  saleOrderId             String?
  saleOrder               SaleOrder?      @relation(fields: [saleOrderId], references: [id])
  serviceOrderId          String?
  serviceOrder            ServiceOrder?   @relation(fields: [serviceOrderId], references: [id])

  // Datas
  dataEmissao             DateTime?
  dataEntradaSaida        DateTime?

  // Natureza da operação
  naturezaOperacao        String          @db.VarChar(200)

  // Valores dos produtos/serviços
  valorProdutos           Float           @default(0)
  valorFrete              Float           @default(0)
  valorSeguro             Float           @default(0)
  valorDesconto           Float           @default(0)
  valorOutros             Float           @default(0)
  valorTotal              Float           @default(0)

  // Impostos — sistema atual
  valorIcms               Float           @default(0)
  valorIcmsSt             Float           @default(0)
  valorIpi                Float           @default(0)
  valorPis                Float           @default(0)
  valorCofins             Float           @default(0)

  // Impostos — Reforma Tributária (EC 132/2023)
  valorIbs                Float           @default(0) // Imposto sobre Bens e Serviços
  valorCbs                Float           @default(0) // Contribuição sobre Bens e Serviços
  valorIs                 Float           @default(0) // Imposto Seletivo

  // DIFAL — Diferencial de Alíquota (operações interestaduais para consumidor final)
  valorDifal              Float           @default(0) // ICMS DIFAL total
  valorDifalDestino       Float           @default(0) // parte do DIFAL devida ao estado destino
  valorDifalOrigem        Float           @default(0) // parte do DIFAL devida ao estado origem
  valorFcp                Float           @default(0) // Fundo de Combate à Pobreza
  ufDestino               String?         @db.VarChar(2)
  aliqInterestadual       Float?                      // alíquota interestadual aplicada
  aliqInternaDestino      Float?                      // alíquota interna do estado destino

  // Carta de Correção (CC-e)
  cceNumero               Int?
  cceDataEvento           DateTime?
  cceDescricao            String?         @db.Text
  cceProtocolo            String?         @db.VarChar(50)
  cceXml                  String?         @db.Text

  // Informações complementares
  informacoesComplementares String?       @db.Text
  informacoesFisco        String?         @db.Text

  // Autorização SEFAZ
  protocoloAutorizacao    String?         @db.VarChar(50)
  dataAutorizacao         DateTime?

  // XML
  xmlEnvio                String?         @db.Text
  xmlRetorno              String?         @db.Text
  motivoCancelamento      String?         @db.Text

  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  // Relations
  items                   NFeItem[]
  fiscalEntries           FiscalEntry[]

  // Financeiro (Sprint 8)
  financialMovements      FinancialMovement[]

  // Portal (Sprint 10)
  portalDocuments         PortalDocument[]

  // Fluxo de Compras Integrado
  nfeInbox                NFeInbox[]

  @@index([companyId, status])
  @@index([personId])
  @@map("nfe_documents")
}

// ============================================================================
// NF-e ITENS
// ============================================================================

model NFeItem {
  id                      String       @id @default(cuid())
  nfeId                   String
  nfe                     NFeDocument  @relation(fields: [nfeId], references: [id], onDelete: Cascade)
  productId               String?
  product                 Product?     @relation(fields: [productId], references: [id])

  // Identificação do item
  itemNumber              Int
  description             String       @db.VarChar(500)

  // Classificação fiscal
  ncmCode                 String       @db.VarChar(10)
  cfopCode                String       @db.VarChar(4)
  cest                    String?      @db.VarChar(7) // Código Especificador da Substituição Tributária

  // Quantidades e valores
  quantity                Float
  unitPrice               Float
  totalPrice              Float
  unit                    String       @db.VarChar(20)

  // ICMS
  bcIcms                  Float        @default(0)
  aliqIcms                Float        @default(0)
  valorIcms               Float        @default(0)
  cstIcms                 String?      @db.VarChar(3) // CST/CSOSN

  // ICMS-ST
  bcIcmsSt                Float        @default(0)
  aliqIcmsSt              Float        @default(0)
  valorIcmsSt             Float        @default(0)

  // IPI
  bcIpi                   Float        @default(0)
  aliqIpi                 Float        @default(0)
  valorIpi                Float        @default(0)
  cstIpi                  String?      @db.VarChar(2)

  // PIS
  bcPis                   Float        @default(0)
  aliqPis                 Float        @default(0)
  valorPis                Float        @default(0)
  cstPis                  String?      @db.VarChar(2)

  // COFINS
  bcCofins                Float        @default(0)
  aliqCofins              Float        @default(0)
  valorCofins             Float        @default(0)
  cstCofins               String?      @db.VarChar(2)

  // IBS — Reforma Tributária (EC 132/2023)
  bcIbs                   Float        @default(0)
  aliqIbs                 Float        @default(0)
  valorIbs                Float        @default(0)

  // CBS — Reforma Tributária
  bcCbs                   Float        @default(0)
  aliqCbs                 Float        @default(0)
  valorCbs                Float        @default(0)

  // IS — Imposto Seletivo
  bcIs                    Float        @default(0)
  aliqIs                  Float        @default(0)
  valorIs                 Float        @default(0)

  // Destinação fiscal (A2/A4 — permite override por item na NF-e emitida)
  destinacaoFiscal        ItemDestinacao?  // se null, herda de product.destinacaoFiscal

  // Informações adicionais
  informacoesAdicionais   String?      @db.Text

  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  @@index([nfeId])
  @@map("nfe_items")
}

// ============================================================================
// LANÇAMENTOS FISCAIS (LIVROS FISCAIS)
// ============================================================================

model FiscalEntry {
  id                      String          @id @default(cuid())
  companyId               String
  company                 Company         @relation(fields: [companyId], references: [id])

  // Vínculo com NF-e
  nfeId                   String?
  nfe                     NFeDocument?    @relation(fields: [nfeId], references: [id])

  // Classificação
  type                    FiscalEntryType
  bookType                FiscalBookType

  // Período
  dataLancamento          DateTime
  periodoReferencia       String          @db.VarChar(7) // YYYY-MM

  // Operação
  cfopCode                String          @db.VarChar(4)
  naturezaOperacao        String?         @db.VarChar(200)

  // Valores
  valorContabil           Float
  baseCalculo             Float
  aliquota                Float
  valorImposto            Float

  // Tipo de imposto
  taxType                 String          @db.VarChar(10) // ICMS, IPI, PIS, COFINS, IBS, CBS, IS

  // Observações
  observations            String?         @db.Text

  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  @@index([companyId, periodoReferencia])
  @@index([nfeId])
  @@map("fiscal_entries")
}

// ============================================================================
// APURAÇÃO MENSAL DE IMPOSTOS
// ============================================================================

model FiscalApuracao {
  id                      String    @id @default(cuid())
  companyId               String
  company                 Company   @relation(fields: [companyId], references: [id])

  // Período e tipo
  periodoReferencia       String    @db.VarChar(7) // YYYY-MM
  taxType                 String    @db.VarChar(10) // ICMS, IPI, PIS, COFINS, IBS, CBS

  // Valores da apuração
  totalDebitos            Float     @default(0)
  totalCreditos           Float     @default(0)
  saldoAnterior           Float     @default(0)
  deducoesLegais          Float     @default(0)
  ajustesDebito           Float     @default(0)
  ajustesCredito          Float     @default(0)
  impostoAPagar           Float     @default(0)
  saldoCredor             Float     @default(0)

  // Status
  status                  String    @default("ABERTA") @db.VarChar(20) // ABERTA, FECHADA, RETIFICADA
  dataFechamento          DateTime?

  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@unique([companyId, periodoReferencia, taxType])
  @@map("fiscal_apuracoes")
}


// ============================================================================
// MOTOR DE REGRAS FISCAIS (TES — Tipo de Entrada e Saída)
// Equivalente ao TES do TOTVS Protheus — determina CFOP, CST e créditos
// automaticamente pela combinação: destinação × tipo fornecedor × UF × ST
// ============================================================================

model OperacaoFiscal {
  id          String              @id @default(cuid())
  companyId   String
  company     Company             @relation(fields: [companyId], references: [id])

  // Identificação
  codigo      String              @db.VarChar(30)   // ex: "ENT-MP-IND-INTRA"
  descricao   String              @db.VarChar(200)
  tipo        OperacaoFiscalTipo                    // ENTRADA | SAIDA

  // ── CONDIÇÕES DE MATCHING (null = qualquer) ──────────────────────────────
  destinacao      ItemDestinacao?                   // MP | GGF | REVENDA | USO_CONSUMO | IMOBILIZADO | FRETE | SERVICO_TOMADO …
  tipoFornecedor  TipoFornecedor?                   // INDUSTRIA | COMERCIO | SIMPLES …
  intraestadual   Boolean?                          // true=mesmo estado; false=outro estado; null=ambos
  temST           Boolean?                          // true=sujeito à ST; false=sem ST; null=ambos
  freteContaDestinatario Boolean?                   // FRETE: true=FOB (crédita); false=CIF (sem crédito); null=ambos
  // ── CAMPOS ADICIONAIS PARA SAÍDAS ────────────────────────────────────────
  tipoCliente     TipoCliente?                      // saídas: tipo do destinatário (CONTRIBUINTE | CONTRIBUINTE_SIMPLES | NAO_CONTRIBUINTE)
  stRetida        Boolean?                          // saídas: true=ST já retida anteriormente (CST 060/CSOSN 500)
  finalidade      String?         @db.VarChar(30)   // VENDA | REMESSA | DEVOLUCAO | INDUSTRIALIZACAO | TRANSFERENCIA
  regimeTributario TaxRegime?                       // null=qualquer regime; valor=só se empresa neste regime (ex: SIMPLES_NACIONAL)
  prioridade      Int             @default(0)       // maior = mais específico, aplicado primeiro

  // ── RESULTADO: CFOP + CST ─────────────────────────────────────────────────
  cfop            String          @db.VarChar(4)    // "1101", "1556", etc.
  cstIcms         String          @db.VarChar(3)    // "000", "010", "040", "060" …
  cstIpi          String          @db.VarChar(2)    // "00" crédito | "49" sem crédito
  cstPis          String          @db.VarChar(2)    // "50" crédito | "70" sem crédito
  cstCofins       String          @db.VarChar(2)    // "50" crédito | "70" sem crédito

  // ── FLAGS DE CRÉDITO ──────────────────────────────────────────────────────
  creditaIcms         Boolean     @default(false)   // apropria crédito ICMS
  creditaIpi          Boolean     @default(false)   // apropria crédito IPI
  creditaPisCofins    Boolean     @default(false)   // válido só se Lucro Real
  icmsSimplesPCredSN  Boolean     @default(false)   // usa pCredSN do XML (Simples Nacional)
  ciap                Boolean     @default(false)   // ativo imobilizado: CIAP 1/48
  pisCofins24x        Boolean     @default(false)   // ativo imobilizado: crédito em 24 parcelas

  // ── RETENÇÕES (NFS-e tomadas / serviços contratados) ──────────────────────
  retencaoIss      Boolean     @default(false)   // empresa retém ISS na fonte
  retencaoFederal  Boolean     @default(false)   // retenção federal 4,65% (PIS+COFINS+CSLL via IN 1234)
  retencaoInss     Boolean     @default(false)   // retenção INSS 11% sobre mão de obra

  // ── CONTA CONTÁBIL DÉBITO (entrada) ──────────────────────────────────────
  contaDebitoCode String?         @db.VarChar(20)   // "1.1.4.01"=Estoque MP | "3.1.1"=Despesa | "1.2.1"=Ativo

  // Controle
  ativo       Boolean             @default(true)
  isDefault   Boolean             @default(false)   // regra padrão do sistema (não deletável)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([companyId, codigo])
  @@index([companyId, tipo, destinacao, tipoFornecedor, tipoCliente, intraestadual, temST])
  @@map("operacoes_fiscais")
}

// ============================================================================
// SPRINT 8 — CONTABILIDADE (PLANO DE CONTAS, LANÇAMENTOS CONTÁBEIS)
// ============================================================================

model ChartOfAccount {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  parentId        String?
  parent          ChartOfAccount?  @relation("ChartOfAccountParent", fields: [parentId], references: [id])
  children        ChartOfAccount[] @relation("ChartOfAccountParent")
  code            String        @db.VarChar(50)
  name            String        @db.VarChar(200)
  type            AccountType
  nature          AccountNature
  level           Int
  acceptsEntries  Boolean       @default(true)
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  journalEntryItems   JournalEntryItem[]
  financialMovements  FinancialMovement[] @relation("FinancialMovementCategory")
  cashFlows           CashFlow[]          @relation("CashFlowCategory")

  @@unique([companyId, code])
  @@map("chart_of_accounts")
}

model JournalEntry {
  id            String             @id @default(cuid())
  companyId     String
  company       Company            @relation(fields: [companyId], references: [id])
  numero        String             @db.VarChar(50)
  date          DateTime
  description   String             @db.Text
  status        JournalEntryStatus @default(RASCUNHO)
  totalValue    Decimal            @db.Decimal(15, 2)
  userId        String
  user          User               @relation(fields: [userId], references: [id])
  reversalOfId  String?
  reversalOf    JournalEntry?      @relation("JournalEntryReversal", fields: [reversalOfId], references: [id])
  reversals     JournalEntry[]     @relation("JournalEntryReversal")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  // Relations
  items                  JournalEntryItem[]
  adiantamentoMovimentos AdiantamentoMovimento[] @relation("AdiantamentoMovJournal")

  @@unique([companyId, numero])
  @@map("journal_entries")
}

model JournalEntryItem {
  id              String         @id @default(cuid())
  journalEntryId  String
  journalEntry    JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId       String
  account         ChartOfAccount @relation(fields: [accountId], references: [id])
  type            AccountNature
  value           Decimal        @db.Decimal(15, 2)
  costCenterId    String?
  costCenter      CostCenter?    @relation(fields: [costCenterId], references: [id])
  description     String?        @db.Text
  createdAt       DateTime       @default(now())

  @@map("journal_entry_items")
}

// ============================================================================
// SPRINT 8 — FINANCEIRO (CONTAS BANCÁRIAS, CONTAS A PAGAR/RECEBER, EXTRATO)
// ============================================================================

model BankAccount {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  name          String    @db.VarChar(200)
  banco         String    @db.VarChar(10)
  agencia       String    @db.VarChar(20)
  conta         String    @db.VarChar(20)
  tipoConta     String    @db.VarChar(20)
  saldoInicial  Decimal   @default(0) @db.Decimal(15, 2)
  saldoAtual    Decimal   @default(0) @db.Decimal(15, 2)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  financialMovements      FinancialMovement[]
  bankTransactions        BankTransaction[]
  cashFlows               CashFlow[]                 @relation("CashFlowBankAccount")
  adiantamentoMovimentos  AdiantamentoMovimento[]

  @@unique([companyId, banco, agencia, conta])
  @@map("bank_accounts")
}

model FinancialMovement {
  id                String                   @id @default(cuid())
  companyId         String
  company           Company                  @relation(fields: [companyId], references: [id])
  type              FinancialMovementType
  personId          String
  person            Person                   @relation(fields: [personId], references: [id])
  description       String                   @db.Text
  numero            String                   @db.VarChar(50)
  parcela           Int                      @default(1)
  totalParcelas     Int                      @default(1)
  valor             Decimal                  @db.Decimal(15, 2)
  valorPago         Decimal?                 @db.Decimal(15, 2)
  dataEmissao       DateTime
  dataVencimento    DateTime
  dataPagamento     DateTime?
  paymentMethod     PaymentMethod?
  bankAccountId     String?
  bankAccount       BankAccount?             @relation(fields: [bankAccountId], references: [id])
  categoryId        String?
  category          ChartOfAccount?          @relation("FinancialMovementCategory", fields: [categoryId], references: [id])
  costCenterId      String?
  costCenter        CostCenter?              @relation(fields: [costCenterId], references: [id])
  status            FinancialMovementStatus  @default(PENDENTE)
  nfeDocumentId     String?
  nfeDocument       NFeDocument?             @relation(fields: [nfeDocumentId], references: [id])
  saleOrderId       String?
  saleOrder         SaleOrder?               @relation(fields: [saleOrderId], references: [id])
  cteDocumentId     String?                  // CT-e de frete que gerou este título
  observations      String?                  @db.Text

  // Retenções na fonte (para REINF R-4020 e DCTF-Web)
  valorIrRetido     Decimal                  @default(0) @db.Decimal(15, 2)
  valorBaseIr       Decimal                  @default(0) @db.Decimal(15, 2)
  aliqIr            Decimal                  @default(0) @db.Decimal(10, 4)

  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  // Relations
  bankTransactions  BankTransaction[]

  @@index([companyId, status, dataVencimento])
  @@map("financial_movements")
}

model BankTransaction {
  id                    String              @id @default(cuid())
  companyId             String
  company               Company             @relation(fields: [companyId], references: [id])
  bankAccountId         String
  bankAccount           BankAccount         @relation(fields: [bankAccountId], references: [id])
  type                  BankTransactionType
  date                  DateTime
  value                 Decimal             @db.Decimal(15, 2)
  balance               Decimal             @db.Decimal(15, 2)
  description           String              @db.Text
  financialMovementId   String?
  financialMovement     FinancialMovement?  @relation(fields: [financialMovementId], references: [id])
  reconciled            Boolean             @default(false)
  createdAt             DateTime            @default(now())

  @@index([bankAccountId, date])
  @@map("bank_transactions")
}

model CashFlow {
  id              String                @id @default(cuid())
  companyId       String
  company         Company               @relation(fields: [companyId], references: [id])
  date            DateTime
  description     String                @db.Text
  type            FinancialMovementType
  valorPrevisto   Decimal               @db.Decimal(15, 2)
  valorRealizado  Decimal?              @db.Decimal(15, 2)
  categoryId      String?
  category        ChartOfAccount?       @relation("CashFlowCategory", fields: [categoryId], references: [id])
  bankAccountId   String?
  bankAccount     BankAccount?          @relation("CashFlowBankAccount", fields: [bankAccountId], references: [id])
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@map("cash_flows")
}

// ============================================================================
// DRE — DEMONSTRATIVO DE RESULTADO DO EXERCÍCIO
// ============================================================================

model DreApuracao {
  id                  String   @id @default(cuid())
  companyId           String
  company             Company  @relation(fields: [companyId], references: [id])

  periodoReferencia   String   @db.VarChar(7)  // "YYYY-MM"
  tipo                String   @default("MENSAL") // MENSAL | TRIMESTRAL | ANUAL

  // Receitas
  receitaBrutaVendas     Decimal @db.Decimal(15, 2) @default(0)
  receitaBrutaServicos   Decimal @db.Decimal(15, 2) @default(0)
  deducoesReceita        Decimal @db.Decimal(15, 2) @default(0)
  receitaLiquida         Decimal @db.Decimal(15, 2) @default(0)

  // Custos
  custoMercadorias       Decimal @db.Decimal(15, 2) @default(0)
  custoServicos          Decimal @db.Decimal(15, 2) @default(0)
  lucroBruto             Decimal @db.Decimal(15, 2) @default(0)

  // Despesas Operacionais
  despesasVendas         Decimal @db.Decimal(15, 2) @default(0)
  despesasAdm            Decimal @db.Decimal(15, 2) @default(0)
  despesasGerais         Decimal @db.Decimal(15, 2) @default(0)
  ebitda                 Decimal @db.Decimal(15, 2) @default(0)

  // Resultado Financeiro
  receitasFinanceiras    Decimal @db.Decimal(15, 2) @default(0)
  despesasFinanceiras    Decimal @db.Decimal(15, 2) @default(0)
  resultadoFinanceiro    Decimal @db.Decimal(15, 2) @default(0)

  // Resultado Final
  lair                   Decimal @db.Decimal(15, 2) @default(0)
  irpj                   Decimal @db.Decimal(15, 2) @default(0)
  csll                   Decimal @db.Decimal(15, 2) @default(0)
  lucroLiquido           Decimal @db.Decimal(15, 2) @default(0)

  calculadoEm            DateTime @default(now())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([companyId, periodoReferencia, tipo])
  @@map("dre_apuracoes")
}

// ============================================================================
// SPRINT 8 — RH (FUNCIONÁRIOS, FOLHA DE PAGAMENTO, BENEFÍCIOS)
// ============================================================================

model Employee {
  id              String         @id @default(cuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  personId        String
  person          Person         @relation(fields: [personId], references: [id])
  userId          String?
  user            User?          @relation("EmployeeUser", fields: [userId], references: [id])
  matricula       String         @db.VarChar(50)
  cargo           String         @db.VarChar(200)
  departamento    String         @db.VarChar(200)
  costCenterId    String?
  costCenter      CostCenter?    @relation(fields: [costCenterId], references: [id])
  dataAdmissao    DateTime
  dataDemissao    DateTime?
  salarioBase     Decimal        @db.Decimal(15, 2)
  status          EmployeeStatus @default(ATIVO)
  ctps            String?        @db.VarChar(30)
  pis             String?        @db.VarChar(20)
  jornadaSemanal  Int            @default(44)
  bancoHoras      Decimal        @default(0) @db.Decimal(10, 2)
  observations    String?        @db.Text

  // Apontamentos
  apontamentoRole ApontamentoRole @default(OPERADOR)
  jornadaId       String?
  jornada         JornadaTrabalho? @relation("EmployeeJornada", fields: [jornadaId], references: [id])

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  payrollItems    PayrollItem[]
  benefits        EmployeeBenefit[]
  apontamentos    Apontamento[]

  @@unique([companyId, matricula])
  @@map("employees")
}

model Payroll {
  id                  String        @id @default(cuid())
  companyId           String
  company             Company       @relation(fields: [companyId], references: [id])
  periodoReferencia   String        @db.VarChar(7) // YYYY-MM
  type                PayrollType   @default(MENSAL)
  status              PayrollStatus @default(RASCUNHO)
  dataCalculo         DateTime?
  dataPagamento       DateTime?
  totalBruto          Decimal       @default(0) @db.Decimal(15, 2)
  totalDescontos      Decimal       @default(0) @db.Decimal(15, 2)
  totalLiquido        Decimal       @default(0) @db.Decimal(15, 2)
  totalEncargos       Decimal       @default(0) @db.Decimal(15, 2)
  observations        String?       @db.Text
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  items               PayrollItem[]

  @@unique([companyId, periodoReferencia, type])
  @@map("payrolls")
}

model PayrollItem {
  id                String    @id @default(cuid())
  payrollId         String
  payroll           Payroll   @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employeeId        String
  employee          Employee  @relation(fields: [employeeId], references: [id])
  salarioBase       Decimal   @db.Decimal(15, 2)
  horasExtras       Decimal   @default(0) @db.Decimal(10, 2)
  valorHorasExtras  Decimal   @default(0) @db.Decimal(15, 2)
  adicionalNoturno  Decimal   @default(0) @db.Decimal(15, 2)
  periculosidade    Decimal   @default(0) @db.Decimal(15, 2)
  insalubridade     Decimal   @default(0) @db.Decimal(15, 2)
  outrosProventos   Decimal   @default(0) @db.Decimal(15, 2)
  totalBruto        Decimal   @db.Decimal(15, 2)
  inss              Decimal   @default(0) @db.Decimal(15, 2)
  irrf              Decimal   @default(0) @db.Decimal(15, 2)
  valeTransporte    Decimal   @default(0) @db.Decimal(15, 2)
  valeRefeicao      Decimal   @default(0) @db.Decimal(15, 2)
  outrosDescontos   Decimal   @default(0) @db.Decimal(15, 2)
  totalDescontos    Decimal   @db.Decimal(15, 2)
  totalLiquido      Decimal   @db.Decimal(15, 2)
  fgts              Decimal   @default(0) @db.Decimal(15, 2)
  inssPatronal      Decimal   @default(0) @db.Decimal(15, 2)
  createdAt         DateTime  @default(now())

  @@map("payroll_items")
}

model EmployeeBenefit {
  id                String      @id @default(cuid())
  employeeId        String
  employee          Employee    @relation(fields: [employeeId], references: [id])
  type              BenefitType
  description       String?     @db.Text
  valorEmpresa      Decimal     @default(0) @db.Decimal(15, 2)
  valorFuncionario  Decimal     @default(0) @db.Decimal(15, 2)
  active            Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@map("employee_benefits")
}

// ============================================================================
// SPRINT 9 — COMPRAS (SOLICITAÇÕES, COTAÇÕES, PEDIDOS DE COMPRA)
// ============================================================================

model PurchaseRequest {
  id              String                @id @default(cuid())
  companyId       String
  company         Company               @relation(fields: [companyId], references: [id])
  numero          String                @db.VarChar(50)
  solicitanteId   String
  solicitante     User                  @relation("PurchaseRequestSolicitante", fields: [solicitanteId], references: [id])
  aprovadorId     String?
  aprovador       User?                 @relation("PurchaseRequestAprovador", fields: [aprovadorId], references: [id])
  description     String                @db.Text
  justificativa   String?               @db.Text
  dataSolicitacao DateTime              @default(now())
  dataAprovacao   DateTime?
  status          PurchaseRequestStatus @default(RASCUNHO)
  priority        Int                   @default(5)
  observations    String?               @db.Text
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  // Relations
  items               PurchaseRequestItem[]
  supplierQuotations  SupplierQuotation[]
  purchaseOrders      PurchaseOrder[]

  @@unique([companyId, numero])
  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id                String          @id @default(cuid())
  purchaseRequestId String
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  productId         String
  product           Product         @relation(fields: [productId], references: [id])
  quantity          Decimal         @db.Decimal(15, 4)
  unit              String          @db.VarChar(20)
  estimatedPrice    Decimal?        @db.Decimal(15, 4)
  description       String?         @db.Text
  createdAt         DateTime        @default(now())

  @@map("purchase_request_items")
}

model SupplierQuotation {
  id                String                  @id @default(cuid())
  companyId         String
  company           Company                 @relation(fields: [companyId], references: [id])
  purchaseRequestId String
  purchaseRequest   PurchaseRequest         @relation(fields: [purchaseRequestId], references: [id])
  supplierId        String
  supplier          Person                  @relation("SupplierQuotationSupplier", fields: [supplierId], references: [id])
  numero            String?                 @db.VarChar(50)
  dataEnvio         DateTime?
  dataResposta      DateTime?
  dataValidade      DateTime?
  status            SupplierQuotationStatus @default(PENDENTE)
  totalValue        Decimal?                @db.Decimal(15, 2)
  prazoEntrega      Int?                    // dias
  condicaoPagamento String?                 @db.VarChar(100)
  observations      String?                 @db.Text
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  // Relations
  items             SupplierQuotationItem[]

  @@map("supplier_quotations")
}

model SupplierQuotationItem {
  id            String            @id @default(cuid())
  quotationId   String
  quotation     SupplierQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId     String
  product       Product           @relation(fields: [productId], references: [id])
  quantity      Decimal           @db.Decimal(15, 4)
  unitPrice     Decimal           @db.Decimal(15, 4)
  totalPrice    Decimal           @db.Decimal(15, 2)
  prazoEntrega  Int?              // dias
  observations  String?           @db.Text
  createdAt     DateTime          @default(now())

  @@map("supplier_quotation_items")
}

model PurchaseOrder {
  id                    String              @id @default(cuid())
  companyId             String
  company               Company             @relation(fields: [companyId], references: [id])
  numero                String              @db.VarChar(50)
  supplierId            String
  supplier              Person              @relation("PurchaseOrderSupplier", fields: [supplierId], references: [id])
  purchaseRequestId     String?
  purchaseRequest       PurchaseRequest?    @relation(fields: [purchaseRequestId], references: [id])
  dataEmissao           DateTime            @default(now())
  dataEntregaPrevista   DateTime?
  dataEntregaReal       DateTime?
  condicaoPagamento     String?             @db.VarChar(100)
  status                PurchaseOrderStatus @default(RASCUNHO)
  subtotal              Decimal             @default(0) @db.Decimal(15, 2)
  desconto              Decimal             @default(0) @db.Decimal(15, 2)
  frete                 Decimal             @default(0) @db.Decimal(15, 2)
  totalValue            Decimal             @default(0) @db.Decimal(15, 2)
  tipoFrete             TipoFrete           @default(SEM_FRETE)
  valorFrete            Decimal             @default(0) @db.Decimal(15, 2)
  valorSeguro           Decimal             @default(0) @db.Decimal(15, 2)
  valorOutrasDespesas   Decimal             @default(0) @db.Decimal(15, 2)
  valorDesconto         Decimal             @default(0) @db.Decimal(15, 2)
  observations          String?             @db.Text
  motivoAlteracao       String?             @db.Text  // Motivo de alterações pós-envio
  finalidadeOperacao    FinalidadeOperacao  @default(INDUSTRIALIZACAO) // Impacta CFOP e créditos fiscais
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  // Relations
  items                 PurchaseOrderItem[]
  stockMovements        StockMovement[]

  // Fluxo de Compras Integrado
  purchaseReceipts      PurchaseReceipt[]
  nfeInbox              NFeInbox[]
  cteDocuments          CteDocument[]

  @@unique([companyId, numero])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                String             @id @default(cuid())
  purchaseOrderId   String
  purchaseOrder     PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId         String
  product           Product            @relation(fields: [productId], references: [id])
  destinacao        ItemDestinacao     @default(MATERIA_PRIMA)
  quantity          Decimal            @db.Decimal(15, 4)
  quantityReceived  Decimal            @default(0) @db.Decimal(15, 4)
  unit              String             @db.VarChar(20)
  unitPrice         Decimal            @db.Decimal(15, 4)
  totalPrice        Decimal            @db.Decimal(15, 2)
  icms              Decimal            @default(0) @db.Decimal(15, 2)
  ipi               Decimal            @default(0) @db.Decimal(15, 2)
  observations      String?            @db.Text

  // Sprint 2.2 — Aprovação parcial por item
  statusAprovacao   ItemApprovalStatus @default(PENDENTE)
  quantidadeAprovada Decimal?          @db.Decimal(15, 4)
  motivoRejeicao    String?            @db.Text

  createdAt         DateTime           @default(now())

  @@map("purchase_order_items")
}

// ============================================================================
// SPRINT 9 — ESTOQUE (LOCAIS, SALDOS, MOVIMENTAÇÕES, INVENTÁRIO)
// ============================================================================

model StockLocation {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  code        String    @db.VarChar(50)
  name        String    @db.VarChar(200)
  description String?   @db.Text
  type        String    @db.VarChar(20) // ALMOXARIFADO, PRODUCAO, EXPEDICAO, QUARENTENA
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  stockBalances           StockBalance[]
  stockMovements          StockMovement[]   @relation("StockMovementLocation")
  stockMovementsDestino   StockMovement[]   @relation("StockMovementLocationDestination")
  inventories             Inventory[]
  stockReservations       StockReservation[]  // Sprint 2

  @@unique([companyId, code])
  @@map("stock_locations")
}

model StockBalance {
  id                String        @id @default(cuid())
  companyId         String
  company           Company       @relation(fields: [companyId], references: [id])
  productId         String
  product           Product       @relation(fields: [productId], references: [id])
  locationId        String
  location          StockLocation @relation(fields: [locationId], references: [id])
  quantity          Decimal       @default(0) @db.Decimal(15, 4)
  reservedQuantity  Decimal       @default(0) @db.Decimal(15, 4)
  availableQuantity Decimal       @default(0) @db.Decimal(15, 4)
  averageCost       Decimal       @default(0) @db.Decimal(15, 4)
  totalCost         Decimal       @default(0) @db.Decimal(15, 2)
  minStock          Decimal       @default(0) @db.Decimal(15, 4)
  maxStock          Decimal       @default(0) @db.Decimal(15, 4)
  reorderPoint      Decimal       @default(0) @db.Decimal(15, 4)
  lastMovementAt    DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([productId, locationId])
  @@index([companyId, productId])
  @@map("stock_balances")
}

model StockMovement {
  id                    String              @id @default(cuid())
  companyId             String
  company               Company             @relation(fields: [companyId], references: [id])
  productId             String
  product               Product             @relation(fields: [productId], references: [id])
  locationId            String
  location              StockLocation       @relation("StockMovementLocation", fields: [locationId], references: [id])
  locationDestinationId String?
  locationDestination   StockLocation?      @relation("StockMovementLocationDestination", fields: [locationDestinationId], references: [id])
  type                  StockMovementType
  source                StockMovementSource
  quantity              Decimal             @db.Decimal(15, 4)
  unitCost              Decimal             @default(0) @db.Decimal(15, 4)
  totalCost             Decimal             @default(0) @db.Decimal(15, 2)
  date                  DateTime            @default(now())
  documentNumber        String?             @db.VarChar(50)
  purchaseOrderId       String?
  purchaseOrder         PurchaseOrder?      @relation(fields: [purchaseOrderId], references: [id])
  saleOrderId           String?
  saleOrder             SaleOrder?          @relation(fields: [saleOrderId], references: [id])
  productionOrderId     String?
  productionOrder       ProductionOrder?    @relation(fields: [productionOrderId], references: [id])
  requisitionId         String?
  requisition           Requisition?        @relation(fields: [requisitionId], references: [id])
  nfeInboxId            String?
  nfeInbox              NFeInbox?           @relation("StockMovementNfeInbox", fields: [nfeInboxId], references: [id])
  userId                String
  user                  User                @relation("StockMovementUser", fields: [userId], references: [id])
  observations          String?             @db.Text
  createdAt             DateTime            @default(now())

  @@index([companyId, productId, date])
  @@map("stock_movements")
}

model Inventory {
  id              String          @id @default(cuid())
  companyId       String
  company         Company         @relation(fields: [companyId], references: [id])
  numero          String          @db.VarChar(50)
  locationId      String
  location        StockLocation   @relation(fields: [locationId], references: [id])
  description     String?         @db.Text
  dataInicio      DateTime
  dataFim         DateTime?
  status          InventoryStatus @default(PLANEJADO)
  responsavelId   String
  responsavel     User            @relation("InventoryResponsavel", fields: [responsavelId], references: [id])
  observations    String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  items           InventoryItem[]

  @@unique([companyId, numero])
  @@map("inventories")
}

model InventoryItem {
  id                String    @id @default(cuid())
  inventoryId       String
  inventory         Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  productId         String
  product           Product   @relation(fields: [productId], references: [id])
  quantidadeSistema Decimal   @db.Decimal(15, 4)
  quantidadeContada Decimal?  @db.Decimal(15, 4)
  diferenca         Decimal?  @db.Decimal(15, 4)
  custoUnitario     Decimal   @default(0) @db.Decimal(15, 4)
  valorDiferenca    Decimal   @default(0) @db.Decimal(15, 2)
  justificativa     String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("inventory_items")
}

// ============================================================================
// SPRINT 10 — ASSISTENTE IA (CONVERSAS, MENSAGENS, FERRAMENTAS, INSIGHTS)
// ============================================================================

model AiConversation {
  id              String               @id @default(cuid())
  companyId       String
  company         Company              @relation(fields: [companyId], references: [id])
  userId          String
  user            User                 @relation(fields: [userId], references: [id])
  title           String?              @db.VarChar(300)
  context         String?              @db.VarChar(100) // module context like "financeiro", "estoque"
  status          AiConversationStatus @default(ATIVA)
  messageCount    Int                  @default(0)
  lastMessageAt   DateTime?
  metadata        Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  // Relations
  messages        AiMessage[]

  @@index([companyId, userId])
  @@map("ai_conversations")
}

model AiMessage {
  id              String        @id @default(cuid())
  conversationId  String
  conversation    AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            AiMessageRole
  content         String        @db.Text
  toolCalls       Json?         // array of tool calls made
  toolResults     Json?         // results from tool calls
  tokens          Int?
  latencyMs       Int?
  createdAt       DateTime      @default(now())

  // Relations
  toolExecutions  AiToolExecution[]

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}

model AiToolExecution {
  id              String     @id @default(cuid())
  companyId       String
  company         Company    @relation(fields: [companyId], references: [id])
  messageId       String
  message         AiMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  toolType        AiToolType
  input           Json
  output          Json?
  success         Boolean    @default(false)
  errorMessage    String?    @db.Text
  executionTimeMs Int?
  createdAt       DateTime   @default(now())

  @@map("ai_tool_executions")
}

model AiInsight {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  title       String    @db.VarChar(300)
  description String    @db.Text
  category    String    @db.VarChar(100) // e.g. "financeiro", "estoque", "producao"
  severity    String    @db.VarChar(20)  // "info", "warning", "critical"
  data        Json?
  actionable  Boolean   @default(false)
  actionUrl   String?   @db.VarChar(500)
  dismissed   Boolean   @default(false)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("ai_insights")
}

// ============================================================================
// SPRINT 10 — PORTAL DO CLIENTE (USUÁRIOS, TICKETS, DOCUMENTOS)
// ============================================================================

model PortalUser {
  id          String            @id @default(cuid())
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id])
  personId    String
  person      Person            @relation(fields: [personId], references: [id])
  email       String            @db.VarChar(200)
  passwordHash String           @db.VarChar(200)
  name        String            @db.VarChar(200)
  accessLevel PortalAccessLevel @default(VISUALIZAR)
  active      Boolean           @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  tickets         PortalTicket[]
  ticketMessages  PortalTicketMessage[]
  portalDocuments PortalDocument[]
  notifications   Notification[]

  @@unique([companyId, email])
  @@map("portal_users")
}

model PortalTicket {
  id            String               @id @default(cuid())
  companyId     String
  company       Company              @relation(fields: [companyId], references: [id])
  portalUserId  String
  portalUser    PortalUser           @relation(fields: [portalUserId], references: [id])
  assignedToId  String?
  assignedTo    User?                @relation("PortalTicketAssigned", fields: [assignedToId], references: [id])
  subject       String               @db.VarChar(300)
  description   String               @db.Text
  status        PortalTicketStatus   @default(ABERTO)
  priority      PortalTicketPriority @default(MEDIA)
  category      String?              @db.VarChar(100)
  closedAt      DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  // Relations
  messages      PortalTicketMessage[]

  @@index([companyId, status])
  @@map("portal_tickets")
}

model PortalTicketMessage {
  id            String      @id @default(cuid())
  ticketId      String
  ticket        PortalTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  portalUserId  String?
  portalUser    PortalUser?  @relation(fields: [portalUserId], references: [id])
  userId        String?
