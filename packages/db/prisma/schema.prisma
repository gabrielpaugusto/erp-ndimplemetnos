  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  nfseEmitidas  NfseEmitida[]
  nfseRecebidas NfseRecebida[]

  @@map("lc116_servicos")
}

model NfseEmitida {
  id                 String     @id @default(cuid())
  companyId          String
  company            Company    @relation(fields: [companyId], references: [id])

  // Numeração
  numero             Int
  serie              String     @default("1") @db.VarChar(3)

  // Tomador (quem recebe o serviço)
  tomadorCpfCnpj     String     @db.VarChar(14)
  tomadorNome        String     @db.VarChar(150)
  tomadorIe          String?    @db.VarChar(20)
  tomadorIm          String?    @db.VarChar(20)
  tomadorEmail       String?    @db.VarChar(100)
  tomadorTelefone    String?    @db.VarChar(20)

  // Endereço tomador
  tomadorLogradouro  String?    @db.VarChar(125)
  tomadorNumero      String?    @db.VarChar(10)
  tomadorComplemento String?    @db.VarChar(60)
  tomadorBairro      String?    @db.VarChar(60)
  tomadorMunicipio   String?    @db.VarChar(60)
  tomadorCodMunicipio String?   @db.VarChar(7)
  tomadorUf          String?    @db.VarChar(2)
  tomadorCep         String?    @db.VarChar(8)

  // Serviço
  nbsCodeId          String?
  nbsCode            NbsCode?   @relation(fields: [nbsCodeId], references: [id])
  lc116ServicoId     String?
  lc116Servico       Lc116Servico? @relation(fields: [lc116ServicoId], references: [id])
  discriminacao      String     @db.Text

  // Valores
  valorServico       Decimal    @db.Decimal(15,2)
  valorDeducoes      Decimal    @default(0) @db.Decimal(15,2)
  valorPis           Decimal    @default(0) @db.Decimal(15,2)
  valorCofins        Decimal    @default(0) @db.Decimal(15,2)
  valorInss          Decimal    @default(0) @db.Decimal(15,2)
  valorIr            Decimal    @default(0) @db.Decimal(15,2)
  valorCsll          Decimal    @default(0) @db.Decimal(15,2)
  valorIss           Decimal    @default(0) @db.Decimal(15,2)
  aliquotaIss        Float      @default(0)
  valorLiquidoNfse   Decimal    @default(0) @db.Decimal(15,2)
  issRetido          Boolean    @default(false)

  // Reforma Tributária (EC 132/2023 + LC 214/2025)
  valorCbs           Decimal    @default(0) @db.Decimal(15,2)
  valorIbs           Decimal    @default(0) @db.Decimal(15,2)
  usouSistemaNovo    Boolean    @default(false)

  // Datas
  dataEmissao        DateTime   @default(now())
  dataCompetencia    DateTime

  // Resposta RFB
  status             NfseStatus @default(PENDENTE)
  codigoVerificacao  String?    @db.VarChar(50)
  linkNfse           String?    @db.VarChar(500)
  xmlEnviado         String?    @db.Text
  xmlRetorno         String?    @db.Text
  motivoCancelamento String?    @db.VarChar(255)

  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@map("nfse_emitidas")
}

model NfseRecebida {
  id                 String     @id @default(cuid())
  companyId          String
  company            Company    @relation(fields: [companyId], references: [id])

  // Dados da nota
  numero             String     @db.VarChar(20)
  codigoVerificacao  String?    @db.VarChar(50)

  // Prestador (quem emitiu)
  prestadorCnpj      String     @db.VarChar(14)
  prestadorNome      String     @db.VarChar(150)
  prestadorIm        String?    @db.VarChar(20)
  prestadorMunicipio String?    @db.VarChar(60)
  prestadorUf        String?    @db.VarChar(2)

  // Serviço
  nbsCodeId          String?
  nbsCode            NbsCode?   @relation(fields: [nbsCodeId], references: [id])
  lc116ServicoId     String?
  lc116Servico       Lc116Servico? @relation(fields: [lc116ServicoId], references: [id])
  discriminacao      String?    @db.Text

  // Valores
  valorServico       Decimal    @db.Decimal(15,2)
  valorPis           Decimal    @default(0) @db.Decimal(15,2)
  valorCofins        Decimal    @default(0) @db.Decimal(15,2)
  valorInss          Decimal    @default(0) @db.Decimal(15,2)
  valorIr            Decimal    @default(0) @db.Decimal(15,2)
  valorCsll          Decimal    @default(0) @db.Decimal(15,2)
  valorIss           Decimal    @default(0) @db.Decimal(15,2)
  aliquotaIss        Float      @default(0)
  issRetido          Boolean    @default(false)
  prestadorRegime    TaxRegime?   // regime do prestador para regras de retenção

  // Retenções calculadas pelo sistema (como tomador)
  valorPisRetido     Decimal    @default(0) @db.Decimal(15,2)
  valorCofinsRetido  Decimal    @default(0) @db.Decimal(15,2)
  valorCsllRetido    Decimal    @default(0) @db.Decimal(15,2)
  valorIrRetido      Decimal    @default(0) @db.Decimal(15,2)
  valorIssAReter     Decimal    @default(0) @db.Decimal(15,2)

  // Datas
