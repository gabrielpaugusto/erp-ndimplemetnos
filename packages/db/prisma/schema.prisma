// ============================================================================
// EMPRESA (CNPJ ÚNICO)
// ============================================================================

model Company {
  id                  String    @id @default(cuid())
  cnpj                String    @unique @db.VarChar(14)
  razaoSocial         String    @db.VarChar(200)
  nomeFantasia        String?   @db.VarChar(200)
  inscricaoEstadual   String?   @db.VarChar(20)
  inscricaoMunicipal  String?   @db.VarChar(20)

  // Endereço
  logradouro          String?   @db.VarChar(200)
  numero              String?   @db.VarChar(10)
  complemento         String?   @db.VarChar(100)
  bairro              String?   @db.VarChar(100)
  codigoMunicipioIbge String?   @db.VarChar(7)
  municipio           String?   @db.VarChar(100)
  uf                  String?   @db.VarChar(2)
  cep                 String?   @db.VarChar(8)

  // Contato
  telefone            String?   @db.VarChar(20)
  email               String?   @db.VarChar(200)

  // Fiscal
  taxRegime           TaxRegime @default(LUCRO_REAL)
  issRetidoMunicipio  Boolean   @default(false)  // município exige retenção de ISS na fonte
  cnaePrincipal       String?   @db.VarChar(10) // 2920-4/01
  mvaPadrao           Float     @default(30.0)  // MVA padrão % para ST quando não há tabela por UF

  // CFOP padrão por empresa (override do CFOP_MAP automático do FiscalEngine)
  cfopPadraoNfeSaida      String  @default("5102") @db.VarChar(5) // NF-e saída intraestadual
  cfopPadraoNfeSaidaInter String  @default("6102") @db.VarChar(5) // NF-e saída interestadual
  cfopPadraoCteEntrada    String  @default("2352") @db.VarChar(5) // CT-e entrada (fallback quando XML não traz CFOP)

  // CST / CSOSN padrão por empresa (regime normal e Simples Nacional)
  cstIcmsPadrao       String  @default("00")  @db.VarChar(3)  // CST ICMS saída (regime normal)
  csosnPadrao         String  @default("102") @db.VarChar(3)  // CSOSN saída (Simples Nacional)

  // Certificado Digital
  certDigitalBase64   String?   @db.Text // A1 — armazenado criptografado
  certDigitalSenha    String?   @db.VarChar(500) // criptografada (base64 de dado criptografado)
  certDigitalValidade DateTime?
  certDigitalConteudo Bytes?    // .pfx file content, encrypted
  certDigitalCn       String?   // Common Name (CN) from certificate

  // Ambientes por módulo fiscal (1=produção, 2=homologação)
  ambienteSefaz       Int       @default(2) // legado / padrão global
  ambienteNfe         Int       @default(2) // NF-e
  ambienteNfce        Int       @default(2) // NFC-e
  ambienteNfse        Int       @default(2) // NFS-e
  ambienteSped        Int       @default(2) // SPED Fiscal / EFD
  ambienteEsocial     Int       @default(2) // e-Social
  ambienteReinf       Int       @default(2) // REINF
  ambienteDctfweb     Int       @default(2) // DCTFWeb
  ambienteDFe         Int       @default(2) // DF-e (NFeDistribuicaoDFe — NF-e, CT-e, MDF-e, eventos)

  // NF-e config
  serieNfe            Int       @default(1)
  serieNfce           Int       @default(1)
  proximoNumeroNfe    Int       @default(1)
  proximoNumeroNfce   Int       @default(1)

  // CT-e config
  serieCte            String    @default("1") @db.VarChar(3)
  proximoNumeroCte    Int       @default(1)

  // MDF-e config
  serieMdfe           String    @default("1") @db.VarChar(3)
  proximoNumeroMdfe   Int       @default(1)

  // NFS-e config
  serieNfse           String    @default("1") @db.VarChar(3)
  proximoNumeroNfse   Int       @default(1)
  lastNfseRecebidaSync DateTime? // última sincronização de NFS-e recebidas com RFB
  ultimoNsuNfse       BigInt    @default(0)  // último NSU processado na API ADN Contribuinte

  // Controle de início de operação no sistema
  dataInicioOperacao  DateTime? // Data a partir da qual o sistema é considerado ativo (ignora obrigações/docs anteriores)

  // Metadata
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  cnaes               CompanyCnae[]
  costCenters         CostCenter[]
  users               User[]
  userCompanies       UserCompany[]
  taxRegimeConfigs    TaxRegimeConfig[]
  operacoesFiscais    OperacaoFiscal[]
  persons             Person[]
  products            Product[]
  leads               Lead[]
  quotations          Quotation[]
  saleOrders          SaleOrder[]
  financings          Financing[]
  consortiumQuotas    ConsortiumQuota[]
  insurancePolicies   InsurancePolicy[]

  // PCP / Produção
  workCenters           WorkCenter[]
  billsOfMaterial       BillOfMaterial[]
  productionRoutings    ProductionRouting[]
  productionOrders      ProductionOrder[]
  productionPointings   ProductionPointing[]

  // Oficina / Calderaria / Requisições
  serviceOrders         ServiceOrder[]
  calderariaOrders      CalderariaOrder[]
  requisitions          Requisition[]

  // Fiscal (Sprint 7)
  nfeDocuments          NFeDocument[]
  fiscalEntries         FiscalEntry[]
  fiscalApuracoes       FiscalApuracao[]

  // Contabilidade / Financeiro / RH (Sprint 8)
  chartOfAccounts       ChartOfAccount[]
  journalEntries        JournalEntry[]
  bankAccounts          BankAccount[]
  financialMovements    FinancialMovement[]
  bankTransactions      BankTransaction[]
  cashFlows             CashFlow[]
  employees             Employee[]
  payrolls              Payroll[]

  // Compras / Estoque (Sprint 9)
  purchaseRequests      PurchaseRequest[]
  purchaseOrders        PurchaseOrder[]
  supplierQuotations    SupplierQuotation[]
  stockLocations        StockLocation[]
  stockBalances         StockBalance[]
  stockMovements        StockMovement[]
  inventories           Inventory[]

  // DRE
  dreApuracoes          DreApuracao[]

  // Fluxo de Compras Integrado
  productSuppliers      ProductSupplier[]
  nfeInbox              NFeInbox[]
  purchaseReceipts      PurchaseReceipt[]
  cteDocuments          CteDocument[]
  mdfeInbox             MdfeInbox[]
  dfeEventos            DFeEvento[]

  // Apontamentos Produtivos (Sprint 11)
  jornadasTrabalho      JornadaTrabalho[]
  feriadosCalendario    FeriadoCalendario[]
  apontamentos          Apontamento[]

  // Adiantamentos
  adiantamentos         Adiantamento[]
  adiantamentoMovimentos AdiantamentoMovimento[]

  // NFS-e (Notas Fiscais de Serviço Eletrônicas)
  nfseEmitidas          NfseEmitida[]
  nfseRecebidas         NfseRecebida[]

  // SEFAZ Audit Log
  sefazAuditLogs        SefazAuditLog[]

  // Alíquotas configuráveis por regime
  taxRates              CompanyTaxRate[]

  // IA / Portal / Notificações (Sprint 10)
  aiConversations       AiConversation[]
  aiInsights            AiInsight[]
  aiToolExecutions      AiToolExecution[]
  portalUsers           PortalUser[]
  portalTickets         PortalTicket[]
  portalDocuments       PortalDocument[]
  notifications         Notification[]

  // Government Transmission
  governmentTransmissionLogs GovernmentTransmissionLog[]

  // Configuração de retenções e reforma tributária
  taxRetentionConfig    TaxRetentionConfig?

  // Tabelas fiscais de RH
  inssFaixas     InssFaixa[]
  irrfFaixas     IrrfFaixa[]
  payrollConfig  PayrollConfig?

  // Grupos e Subgrupos de Materiais
  productGroups       ProductGroup[]
  productSubgroups    ProductSubgroup[]
  productAbbreviations ProductAbbreviation[]

  // Patrimônio / Ativo Imobilizado (Sprint 4)
  fixedAssets          FixedAsset[]

  // Sistema de Aprovações (Fase 1)
  approvalPolicies     ApprovalPolicy[]
  approvalRequests     ApprovalRequest[]

  // Auditoria NCM
  ncmAuditorias        NcmAuditoria[]

  // Datas de início por módulo fiscal
  moduleStartDates     ModuleStartDate[]

  // Sprint 2 — ERP Dinâmico
  documentFieldLocks   DocumentFieldLock[]
  documentEvents       DocumentEvent[]
  stockReservations    StockReservation[]

  // Sprint 3 — Customização e Engenharia
  orderBomOverrides        OrderBomOverride[]
  engineeringChanges       EngineeringChange[]
  customizationTemplates   CustomizationTemplate[]
  saleOrderCustomizations  SaleOrderCustomization[]

  // Sprint 4 — Inteligência e Decisão
  mrpSuggestions           MrpSuggestion[]
  workflowConfigs          WorkflowConfig[]
  fiscalBrainDecisions     FiscalBrainDecision[]
  excecoesFiscais          ExcecaoFiscal[]

  // FiscalBrain Chat
  fiscalBrainChatMessages  FiscalBrainChatMessage[]

  @@map("companies")
}

// ---------------------------------------------------------------------------
// Módulos fiscais com controle de data de início
// ---------------------------------------------------------------------------
enum FiscalModule {
  NFE_ENTRADA        // NF-e recebidas (sync SEFAZ DistDFe)
  CTE_ENTRADA        // CT-e recebidos (sync SEFAZ DistDFe)
  MDFE_ENTRADA       // MDF-e recebidos (sync SEFAZ DistDFe)
  NFSE_ENTRADA       // NFS-e recebidas (prefeituras)
  NFE_SAIDA          // Emissão de NF-e / autorização SEFAZ
  NFSE_SAIDA         // Emissão de NFS-e
  SPED_ECD           // Escrituração Contábil Digital (ECD)
  SPED_ECF           // Escrituração Contábil Fiscal (ECF)
  EFD_ICMS           // EFD ICMS/IPI (SPED Fiscal)
  EFD_CONTRIBUICOES  // EFD Contribuições (PIS/COFINS)
  ESOCIAL            // e-Social (folha / RH)
  REINF              // EFD-REINF (retenções e serviços)
  DCTFWEB            // DCTFWeb (débitos e créditos tributários)
}

model ModuleStartDate {
  id        String       @id @default(cuid())
  companyId String
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  module    FiscalModule
  startDate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, module])
  @@map("module_start_dates")
}

model CompanyCnae {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  cnae      String  @db.VarChar(10)
  descricao String? @db.VarChar(300)
  principal Boolean @default(false)

  @@unique([companyId, cnae])
  @@map("company_cnaes")
}

// ============================================================================
// CENTROS DE CUSTO
// ============================================================================

model CostCenter {
  id          String         @id @default(cuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id])
  code        CostCenterCode
  name        String         @db.VarChar(100)
  description String?        @db.VarChar(300)
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Sprint 8 relations
  journalEntryItems   JournalEntryItem[]
  financialMovements  FinancialMovement[]
  employees           Employee[]

  @@unique([companyId, code])
  @@map("cost_centers")
}

// ============================================================================
// CONFIGURAÇÃO REGIME TRIBUTÁRIO (REFORMA TRIBUTÁRIA)
// ============================================================================

model TaxRegimeConfig {
  id                    String    @id @default(cuid())
  companyId             String
  company               Company   @relation(fields: [companyId], references: [id])

  // Vigência
  vigenciaInicio        DateTime
  vigenciaFim           DateTime?

  // Sistema ativo
  taxSystem             TaxSystem

  // Proporções na transição (2026-2033)
  anoReferencia         Int?      // 2026, 2027, ..., 2033
  percentualIcms        Decimal?  @db.Decimal(5, 2) // 100% → 0%
  percentualIbs         Decimal?  @db.Decimal(5, 2) // 0% → 100%
  percentualPisCofins   Decimal?  @db.Decimal(5, 2) // 100% → 0%
  percentualCbs         Decimal?  @db.Decimal(5, 2) // 0% → 100%

  // Flags
  cbsAtiva              Boolean   @default(false)
  ibsAtiva              Boolean   @default(false)
  isAtivo               Boolean   @default(false) // Imposto Seletivo
  splitPaymentAtivo     Boolean   @default(false)
  pisCofinsAtiva        Boolean   @default(true)
  icmsAtivo             Boolean   @default(true)
  ipiAtivo              Boolean   @default(true)
  issAtivo              Boolean   @default(true)

  // Metadata
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("tax_regime_configs")
}

// ============================================================================
// USUÁRIOS, ROLES E PERMISSÕES
// ============================================================================

model User {
  id              String     @id @default(cuid())
  companyId       String
  company         Company    @relation(fields: [companyId], references: [id])

  email           String     @unique @db.VarChar(200)
  passwordHash    String     @db.VarChar(200)
  name            String     @db.VarChar(200)
  cpf             String?    @unique @db.VarChar(11)

  status          UserStatus @default(ACTIVE)
  lastLoginAt     DateTime?
  failedAttempts  Int        @default(0)
  lockedUntil     DateTime?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  userCompanies   UserCompany[]
  roles           UserRole[]
  refreshTokens   RefreshToken[]
  auditLogs       AuditLog[]
  leads               Lead[]         @relation("LeadVendedor")
  activities          LeadActivity[] @relation("ActivityUser")
  quotationsVendedor  Quotation[]    @relation("QuotationVendedor")
  saleOrdersVendedor  SaleOrder[]    @relation("SaleOrderVendedor")
  productionPointings ProductionPointing[]

  // Oficina / Calderaria / Requisições
  serviceOrdersResponsavel    ServiceOrder[]    @relation("ServiceOrderResponsavel")
  calderariaOrdersResponsavel CalderariaOrder[] @relation("CalderariaOrderResponsavel")
  requisitionsSolicitante     Requisition[]     @relation("RequisitionSolicitante")
  requisitionsAprovador       Requisition[]     @relation("RequisitionAprovador")

  // Contabilidade / RH (Sprint 8)
  journalEntries              JournalEntry[]
  employees                   Employee[]        @relation("EmployeeUser")

  // Adiantamentos
  adiantamentoMovimentos      AdiantamentoMovimento[] @relation("AdiantamentoMovimentoUser")

  // Compras / Estoque (Sprint 9)
  purchaseRequestsSolicitante PurchaseRequest[] @relation("PurchaseRequestSolicitante")
  purchaseRequestsAprovador   PurchaseRequest[] @relation("PurchaseRequestAprovador")
  stockMovements              StockMovement[]   @relation("StockMovementUser")
  inventoriesResponsavel      Inventory[]       @relation("InventoryResponsavel")

  // Fluxo de Compras Integrado
  purchaseReceiptsResponsavel PurchaseReceipt[] @relation("PurchaseReceiptResponsavel")

  // IA / Portal / Notificações (Sprint 10)
  aiConversations             AiConversation[]
  aiInsights                  AiInsight[]
  portalTicketsAssigned       PortalTicket[]    @relation("PortalTicketAssigned")
  portalTicketMessages        PortalTicketMessage[] @relation("PortalTicketMessageUser")
  notifications               Notification[]

  // Sistema de Aprovações (Fase 1)
  approvalRequestsSolicitante ApprovalRequest[] @relation("ApprovalRequests")
  approvalActions             ApprovalAction[]  @relation("ApprovalActions")

  // Sprint 2 — Timeline de documentos
  documentEvents              DocumentEvent[]

  // Sprint 3 — Engenharia
  bomOverridesAprovados       OrderBomOverride[]    @relation("BomOverrideAprovador")
  ecosSolicitados             EngineeringChange[]   @relation("EcoSolicitante")
  ecosAprovados               EngineeringChange[]   @relation("EcoAprovador")

  @@map("users")
}

// Vínculo M:M entre usuário e empresas (multi-empresa)
// companyId no User continua como "empresa ativa no momento"
model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
  @@map("user_companies")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique @db.VarChar(100)
  description String?      @db.VarChar(300)
  isSystem    Boolean      @default(false) // Roles do sistema não podem ser deletadas
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  users            UserRole[]
  permissions      RolePermission[]

  // Sistema de Aprovações (Fase 1)
  approvalLevels   ApprovalLevel[]
  approvalActions  ApprovalAction[] @relation("ApprovalActionRole")

  @@map("roles")
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Permission {
  id          String           @id @default(cuid())
  module      Module
  action      PermissionAction
  description String?          @db.VarChar(300)

  // Relations
  roles       RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================================================
// AUDITORIA
// ============================================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  module     Module
  action     String   @db.VarChar(50)
  entityType String   @db.VarChar(100)
  entityId   String?  @db.VarChar(100)
  oldData    Json?
  newData    Json?
  ipAddress  String?  @db.VarChar(50)
  userAgent  String?  @db.VarChar(500)
  createdAt  DateTime @default(now())

  @@index([module, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ============================================================================
// CADASTRO UNIFICADO DE PESSOAS
// ============================================================================

model Person {
  id                  String       @id @default(cuid())
  companyId           String
  company             Company      @relation(fields: [companyId], references: [id])

  type                PersonType   // PF ou PJ
  roles               Json         @default("[]") // PersonRole[] — ex: ["CLIENTE", "FORNECEDOR"]

  // Documentos
  cpfCnpj             String       @db.VarChar(14) // CPF (11) ou CNPJ (14)
  razaoSocial         String       @db.VarChar(200) // Nome completo (PF) ou Razão Social (PJ)
  nomeFantasia        String?      @db.VarChar(200)
  rgIe                String?      @db.VarChar(20)  // RG (PF) ou IE (PJ)
  inscricaoMunicipal  String?      @db.VarChar(20)

  // PJ específico
  cnaePrincipal       String?      @db.VarChar(10)
  suframa             String?      @db.VarChar(20)
  taxRegime           TaxRegime?

  // Classificação fiscal do fornecedor (determina IPI, crédito ICMS na entrada)
  tipoFornecedor      TipoFornecedor?

  // Dados fiscais para retenções
  optanteSimples       Boolean   @default(false)    // optante do Simples Nacional
  retencaoIss          Boolean   @default(false)    // retém ISS quando tomador
  retencaoFederal      Boolean   @default(false)    // retém PIS/COFINS/CSLL/IR quando tomador
  retencaoInss         Boolean   @default(false)    // retém INSS quando tomador (cessão mão de obra)
  municipioIbge        String?   @db.VarChar(7)     // código IBGE do município (para regras de ISS)

  // Config comercial
  limiteCredito       Decimal?     @db.Decimal(15, 2)
  condicaoPagamento   String?      @db.VarChar(100)  // ex: "30/60/90"
  tabelaPreco         String?      @db.VarChar(50)
  vendedorId          String?      // referência ao User vendedor responsável
  comissaoPercent     Decimal?     @db.Decimal(5, 2)

  // Observações
  observacoes         String?      @db.Text

  active              Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  // Relations
  addresses           PersonAddress[]
  contacts            PersonContact[]
  bankAccounts        PersonBankAccount[]
  leads               Lead[]
  quotations          Quotation[]
  saleOrders          SaleOrder[]
  saleOrdersFabricante SaleOrder[] @relation("SaleOrderFabricante")
  financings              Financing[]
  financingsFinanceira    Financing[]        @relation("FinancingFinanceira")
  consortiumQuotas        ConsortiumQuota[]
  consortiumAdministradora ConsortiumQuota[] @relation("ConsortiumAdministradora")
  insurancePolicies       InsurancePolicy[]
  insuranceSeguradora     InsurancePolicy[]  @relation("InsuranceSeguradora")

  // Oficina
  serviceOrders           ServiceOrder[]

  // Fiscal (Sprint 7)
  nfeDocuments            NFeDocument[]

  // Financeiro / RH (Sprint 8)
  financialMovements      FinancialMovement[]
  employees               Employee[]

  // Compras (Sprint 9)
  purchaseOrders          PurchaseOrder[]     @relation("PurchaseOrderSupplier")
  supplierQuotations      SupplierQuotation[] @relation("SupplierQuotationSupplier")

  // Fluxo de Compras Integrado
  productSuppliers        ProductSupplier[]   @relation("ProductSupplierPerson")
  nfeInboxEmitente        NFeInbox[]          @relation("NFeInboxEmitente")
  cteTransportadora       CteDocument[]       @relation("CteTransportadora")

  // Portal (Sprint 10)
  portalUsers             PortalUser[]
  portalDocuments         PortalDocument[]

  // Adiantamentos
  adiantamentos           Adiantamento[]  @relation("PersonAdiantamentos")

  // Sprint 4 — MRP
  mrpSuggestions          MrpSuggestion[] @relation("MrpSuggestionSupplier")

  @@unique([companyId, cpfCnpj])
  @@index([razaoSocial])
  @@map("persons")
}

model PersonAddress {
  id                  String      @id @default(cuid())
  personId            String
  person              Person      @relation(fields: [personId], references: [id], onDelete: Cascade)
  type                AddressType @default(PRINCIPAL)
  logradouro          String      @db.VarChar(200)
  numero              String      @db.VarChar(10)
  complemento         String?     @db.VarChar(100)
  bairro              String      @db.VarChar(100)
  codigoMunicipioIbge String      @db.VarChar(7)
  municipio           String      @db.VarChar(100)
  uf                  String      @db.VarChar(2)
  cep                 String      @db.VarChar(8)
  pais                String      @default("BR") @db.VarChar(5)
  principal           Boolean     @default(false)

  @@map("person_addresses")
}

model PersonContact {
  id          String      @id @default(cuid())
  personId    String
  person      Person      @relation(fields: [personId], references: [id], onDelete: Cascade)
  type        ContactType
  value       String      @db.VarChar(200)
  name        String?     @db.VarChar(200) // nome do contato (pessoa)
  department  String?     @db.VarChar(100)
  principal   Boolean     @default(false)

  @@map("person_contacts")
}

model PersonBankAccount {
  id             String  @id @default(cuid())
  personId       String
  person         Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  banco          String  @db.VarChar(10)  // código banco (ex: "001")
  bancoNome      String? @db.VarChar(100)
  agencia        String  @db.VarChar(10)
  conta          String  @db.VarChar(20)
  tipoConta      String  @db.VarChar(20)  // CORRENTE, POUPANCA
  titular        String? @db.VarChar(200)
  cpfCnpjTitular String? @db.VarChar(14)
  chavePix       String? @db.VarChar(200)
  principal      Boolean @default(false)

  @@map("person_bank_accounts")
}

// ============================================================================
// TABELAS FISCAIS
// ============================================================================

model Ncm {
  id                    String    @id @default(cuid())
  code                  String    @unique @db.VarChar(10)   // "8716.39.00"
  description           String    @db.VarChar(500)
  exTipi                String?   @db.VarChar(5)

  // ── Substituição Tributária (ST) ────────────────────────────────
  temSt                 Boolean   @default(false)            // sujeito a ST?
  cestCode              String?   @db.VarChar(7)             // código CEST (sem pontos: "0100100")
  cestDescricao         String?   @db.VarChar(300)           // descrição do segmento CEST

  // ── Importação ──────────────────────────────────────────────────
  aliquotaImportacao    Decimal?  @db.Decimal(5, 2)          // II — Imposto de Importação %

  // ── Geral ───────────────────────────────────────────────────────
  active                Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  products              Product[]

  @@index([code])
  @@map("ncms")
}

model StProtocoloConfaz {
  id             String    @id @default(cuid())
  ufOrigem       String    @db.VarChar(2)
  ufDestino      String    @db.VarChar(2)
  ncm            String    @db.VarChar(10)
  cest           String?   @db.VarChar(7)
  protocolo      String    @db.VarChar(50)
  descricaoProduto String? @db.VarChar(300)
  mvaOriginal    Decimal   @db.Decimal(8, 4)
  mvaAjustado    Decimal?  @db.Decimal(8, 4)
  vigenciaInicio DateTime
  vigenciaFim    DateTime?
  ativo          Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([ufOrigem, ufDestino])
  @@index([ncm])
  @@map("st_protocolo_confaz")
}

/// Código de Benefício Fiscal (pBenef na NF-e) — isenções, reduções de base, diferimentos, etc. por UF
model Cbenef {
  id               String    @id @default(cuid())
  codigo           String    @db.VarChar(10)      // ex: "SP000001" — código oficial da SEFAZ
  uf               String    @db.VarChar(2)        // UF emissora
  descricao        String    @db.VarChar(500)      // descrição do benefício
  tipo             String    @db.VarChar(30)       // ISENCAO | REDUCAO_BASE | DIFERIMENTO | SUSPENSAO | IMUNIDADE | CREDITO_OUTORGADO
  fundamentoLegal  String?   @db.VarChar(500)      // ex: "RICMS/SP Art. 7°, Inc. XIV"
  ncms             String?   @db.VarChar(1000)     // NCMs aplicáveis (vírgula), ou vazio = todos
  percentualReducao Decimal? @db.Decimal(8, 4)     // se tipo = REDUCAO_BASE
  vigenciaInicio   DateTime?
  vigenciaFim      DateTime?
  ativo            Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([codigo, uf])
  @@index([uf])
  @@index([tipo])
  @@map("cbenef")
}

model Cest {
  id             String   @id @default(cuid())
  code           String   @unique @db.VarChar(7)
  codeFormatted  String   @db.VarChar(9)
  segmento       String   @db.VarChar(5)
  description    String   @db.VarChar(500)
  ncmRelacionado String?  @db.VarChar(500)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([code])
  @@index([segmento])
  @@map("cest")
}


model Banco {
  id          String   @id @default(cuid())
  code        String   @unique @db.VarChar(5)
  ispb        String?  @db.VarChar(8)
  name        String   @db.VarChar(200)
  shortName   String?  @db.VarChar(50)
  tipo        String?  @db.VarChar(30)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@map("bancos")
}

model Pais {
  id          String   @id @default(cuid())
  code        String   @unique @db.VarChar(4)
  iso2        String?  @db.VarChar(2)
  iso3        String?  @db.VarChar(3)
  name        String   @db.VarChar(200)
  nameEn      String?  @db.VarChar(200)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([iso2])
  @@map("paises")
}


// ============================================================================
// TABELA DE ABREVIAÇÕES PADRÃO DE MATERIAIS
// ============================================================================

model ProductAbbreviation {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  code        String   @db.VarChar(10)   // ex: SEXT, GALV, ESQ
  fullText    String   @db.VarChar(60)   // ex: Sextavado, Galvanizado, Esquerdo
  category    String?  @db.VarChar(30)   // ex: Material, Posição, Acabamento
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, code])
  @@map("product_abbreviations")
