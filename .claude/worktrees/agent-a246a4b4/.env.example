# ============================================================================
# ERP Implementos - Variaveis de Ambiente
# ============================================================================
# Copie este arquivo para .env.development (dev) ou .env.production (prod)
# e ajuste os valores conforme necessario.
# ============================================================================

# === CORE ===
NODE_ENV=development                # development | production | test
API_PORT=3001                       # Porta da API NestJS
CORS_ORIGIN=http://localhost:3000   # Origem permitida para CORS

# === BANCO DE DADOS ===
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# === AUTENTICACAO (JWT) ===
JWT_SECRET="trocar-em-producao"              # Segredo para tokens de acesso
JWT_REFRESH_SECRET="trocar-em-producao"      # Segredo para refresh tokens
JWT_EXPIRES_IN="15m"                         # Expiracao do access token
JWT_REFRESH_EXPIRES_IN="7d"                  # Expiracao do refresh token

# === REDIS ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                              # Vazio em dev, obrigatorio em prod

# === MINIO (Object Storage) ===
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false                          # true em producao

# ============================================================================
# GOVERNO - CONFIGURACOES FISCAIS
# ============================================================================

# === MASTER SWITCH ===
# 1 = PRODUCAO (documentos fiscais REAIS enviados a SEFAZ)
# 2 = HOMOLOGACAO (ambiente de testes da SEFAZ)
# ATENCAO: Em NODE_ENV=development, GOV_AMBIENTE=1 causa ERRO FATAL!
GOV_AMBIENTE=2

# === CERTIFICADO DIGITAL A1 ===
GOV_CERTIFICADO_A1_PATH=                     # Caminho para o arquivo .pfx
GOV_CERTIFICADO_A1_SENHA=                    # Senha do certificado
GOV_UF_EMITENTE=SP                           # UF do emitente (ex: SP, RJ, MG)
GOV_COD_MUNICIPIO_IBGE=3550308               # Codigo IBGE do municipio

# === NF-e (Nota Fiscal Eletronica) ===
NFE_AMBIENTE=                                # Herda de GOV_AMBIENTE se vazio
NFE_PROVIDER=sefaz_direto                    # sefaz_direto | focus_nfe | tecnospeed
NFE_PROVIDER_URL=                            # URL do provider (se aplicavel)
NFE_PROVIDER_TOKEN=                          # Token do provider (se aplicavel)
NFE_CSC_ID=                                  # CSC ID para NFC-e
NFE_CSC_TOKEN=                               # CSC Token para NFC-e

# === NFS-e (Nota Fiscal de Servicos) ===
NFSE_PROVIDER=abrasf                         # abrasf | issnet | ginfes
NFSE_MUNICIPIO_URL_HOM=                      # URL de homologacao do municipio
NFSE_MUNICIPIO_URL_PROD=                     # URL de producao do municipio
NFSE_USUARIO=                                # Usuario de acesso ao webservice
NFSE_SENHA=                                  # Senha de acesso ao webservice

# === SPED (Sistema Publico de Escrituracao Digital) ===
SPED_AMBIENTE=                               # Herda de GOV_AMBIENTE se vazio
SPED_COD_FINALIDADE=0                        # 0=Remessa original, 1=Retificacao
SPED_PERFIL=A                                # A, B ou C (perfil de enquadramento)

# === eSocial ===
ESOCIAL_AMBIENTE=                            # Herda de GOV_AMBIENTE se vazio
ESOCIAL_URL_HOM=https://webservices.producaorestrita.esocial.gov.br/servicos/empregador/env/WsEnviarLoteEventos/v1
ESOCIAL_URL_PROD=https://webservices.esocial.gov.br/servicos/empregador/env/WsEnviarLoteEventos/v1
ESOCIAL_VERSAO=S-1.2

# === REINF ===
REINF_AMBIENTE=                              # Herda de GOV_AMBIENTE se vazio
REINF_URL_HOM=https://preproducaorestrita.reinf.receita.fazenda.gov.br/WsREINF/RecepcaoLoteReinf.svc
REINF_URL_PROD=https://reinf.receita.fazenda.gov.br/WsREINF/RecepcaoLoteReinf.svc

# === DCTF-Web ===
DCTFWEB_AMBIENTE=                            # Herda de GOV_AMBIENTE se vazio
DCTFWEB_URL_HOM=https://pre-dctfweb.receita.fazenda.gov.br
DCTFWEB_URL_PROD=https://dctfweb.receita.fazenda.gov.br

# === AI (Assistente Inteligente) ===
ANTHROPIC_API_KEY=                           # Chave da API Anthropic (Claude)

# === FRONTEND ===
NEXT_PUBLIC_API_URL=http://localhost:3001/api # URL da API para o Next.js
