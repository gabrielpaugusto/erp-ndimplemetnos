// ============================================================================
// GOVERNMENT TRANSMISSION
// ============================================================================

enum GovernmentTransmissionType {
  NFE
  NFCE
  NFSE
  CTE
  MDFE
  SPED_FISCAL
  SPED_CONTRIBUICOES
  ECD
  ECF
  ESOCIAL
  REINF
  DCTFWEB
}

model GovernmentTransmissionLog {
  id               String   @id @default(cuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])

  type             GovernmentTransmissionType
  ambiente         String   // "1" producao, "2" homologacao
  nodeEnv          String   // "development" or "production"

  // Request
  endpoint         String
  method           String   @default("POST")
  requestXml       String?  @db.Text
  requestPayload   String?  @db.Text

  // Response
  responseXml      String?  @db.Text
  responsePayload  String?  @db.Text
  statusCode       Int?

  // Result
  success          Boolean  @default(false)
  protocolNumber   String?
  receiptNumber    String?
  errorCode        String?
  errorMessage     String?  @db.Text

  // Reference
  documentId       String?  // ID do documento (NF-e, evento eSocial, etc.)
  documentNumber   String?  // Numero do documento

  // Metadata
  userId           String?
  processingTimeMs Int?

  createdAt        DateTime @default(now())

  @@index([companyId, type, createdAt])
  @@index([companyId, ambiente])
  @@index([documentId])
  @@map("government_transmission_logs")
}

// ============================================================================
// FLUXO DE COMPRAS INTEGRADO — CATÁLOGO DE FORNECEDORES, NF-e INBOX, RECEBIMENTO
// ============================================================================

model ProductSupplier {
  id                    String   @id @default(cuid())
  companyId             String
  company               Company  @relation(fields: [companyId], references: [id])
  productId             String
  product               Product  @relation(fields: [productId], references: [id])
  personId              String
  person                Person   @relation("ProductSupplierPerson", fields: [personId], references: [id])

  codigoFornecedor      String   @db.VarChar(100)  // código do produto no fornecedor
  descricaoFornecedor   String   @db.VarChar(500)  // descrição do produto no fornecedor
  unidadeFornecedor     String?  @db.VarChar(20)   // unidade de medida do fornecedor
  fatorConversao        Decimal  @default(1) @db.Decimal(10, 4)  // fator entre unidade fornecedor e interna
  precoUltCompra        Decimal? @db.Decimal(15, 2) // último preço de compra
  prazoEntregaDias      Int?                        // prazo de entrega médio em dias
  preferred             Boolean  @default(false)    // fornecedor preferencial para este produto
  active                Boolean  @default(true)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  nfeInboxItems         NFeInboxItem[]

  @@unique([companyId, productId, personId])
  @@index([companyId, personId])
  @@map("product_suppliers")
}

// ============================================================================
// CT-e — CONHECIMENTO DE TRANSPORTE ELETRÔNICO (ENTRADA / FRETE CONTRATADO)
// ============================================================================
// A empresa não emite CT-e, mas RECEBE de transportadoras nos fretes de compras.
// Este modelo registra o CT-e recebido e dispara as integrações:
//   - Crédito ICMS no livro fiscal (quando insumo de produção, Lucro Real)
//   - Rateio do custo de frete nas mercadorias da NF-e vinculada
//   - Contas a pagar para a transportadora
//   - Lançamento contábil automático (D: Estoque ou Frete / C: Fornecedores)
model CteDocument {
  id                  String          @id @default(cuid())
  companyId           String
  company             Company         @relation(fields: [companyId], references: [id])

  // Identificação do CT-e
  chaveAcesso         String?         @db.VarChar(44)
  numero              String          @db.VarChar(20)
  serie               String          @default("0") @db.VarChar(3)
  dataEmissao         DateTime
  dataEntrega         DateTime?

  // Emissor (transportadora)
  transportadoraId    String?
  transportadora      Person?         @relation("CteTransportadora", fields: [transportadoraId], references: [id])
  transportadoraCnpj  String          @db.VarChar(14)
  transportadoraNome  String          @db.VarChar(200)

  // Remetente e destinatário do transporte
  remetenteCnpj       String?         @db.VarChar(14)
  remetenteNome       String?         @db.VarChar(200)
  destinatarioCnpj    String?         @db.VarChar(14)
  destinatarioNome    String?         @db.VarChar(200)

  // Dados do transporte
  modalidade          CteModalidade   @default(RODOVIARIO)
  naturezaPrestacao   String          @default("PRESTAÇÃO DE SERVIÇO DE TRANSPORTE") @db.VarChar(200)
  cfop                String          @default("2352") @db.VarChar(4) // 1352 intraestadual / 2352 interestadual
  ufInicio            String?         @db.VarChar(2)
  ufFim               String?         @db.VarChar(2)
  pesoTotalKg         Float?

  // Valores financeiros
  valorFrete          Decimal         @db.Decimal(15, 2)  // valor total do frete
  valorSeguro         Decimal         @default(0) @db.Decimal(15, 2)
  valorOutrasDespesas Decimal         @default(0) @db.Decimal(15, 2)
  valorDesconto       Decimal         @default(0) @db.Decimal(15, 2)
  valorTotal          Decimal         @db.Decimal(15, 2)  // total do CT-e

  // ICMS sobre o frete (crédito a recuperar)
  cstIcms             String?         @db.VarChar(3)
  bcIcms              Decimal         @default(0) @db.Decimal(15, 2)
  aliqIcms            Float           @default(12)  // alíquota sobre frete
  valorIcms           Decimal         @default(0) @db.Decimal(15, 2)
  creditoIcms         Boolean         @default(true)  // empresa pode aproveitar o crédito?

  // Condição de pagamento (frete)
  condicaoPagamento   String?         @db.VarChar(100)  // ex: "30 dias"
  dataVencimentoFrete DateTime?

  // Status e manifestação
  status              CteStatus       @default(REGISTRADO)
  manifestacao        CteManifestacao?
  dataManifestacao    DateTime?
  motivoCancelamento  String?         @db.Text

  // XML bruto
  xmlContent          String?         @db.Text

  // Vínculos
  purchaseOrderId     String?
  purchaseOrder       PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id])
  nfeInboxId          String?
  nfeInbox            NFeInbox?       @relation(fields: [nfeInboxId], references: [id])

  // Resultado das integrações (preenchidos ao escriturar)
  financialMovementId String?         // título CP gerado
  journalEntryId      String?         // lançamento contábil gerado
  fiscalEntryId       String?         // escrituração fiscal

  // Rateio de custo: flag indica se o custo já foi rateado na NF-e vinculada
  custoRateado        Boolean         @default(false)
  valorRateadoTotal   Decimal         @default(0) @db.Decimal(15, 2)

  // Observações
  observacoes         String?         @db.Text

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([companyId, status])
  @@index([companyId, dataEmissao])
  @@map("cte_documents")
}

model NFeInbox {
  id                      String           @id @default(cuid())
  companyId               String
  company                 Company          @relation(fields: [companyId], references: [id])

  chaveAcesso             String           @db.VarChar(44)
  numero                  String
  serie                   String
  emitenteCnpj            String           @db.VarChar(14)
  emitenteNome            String
  emitentePessoaId        String?
  emitentePessoa          Person?          @relation("NFeInboxEmitente", fields: [emitentePessoaId], references: [id])
  dataEmissao             DateTime
  valorTotal              Decimal          @db.Decimal(15, 2)
  valorFrete              Decimal          @default(0) @db.Decimal(15, 2)
  valorSeguro             Decimal          @default(0) @db.Decimal(15, 2)
  valorOutrasDespesas     Decimal          @default(0) @db.Decimal(15, 2)
  valorDesconto           Decimal          @default(0) @db.Decimal(15, 2)

  status                  NFeInboxStatus   @default(PENDENTE)
  manifestacao            ManifestacaoType?
  dataManifestacao        DateTime?
  xmlContent              String?          @db.Text  // XML bruto recebido da SEFAZ

  // Vínculos opcionais
  purchaseOrderId         String?
  purchaseOrder           PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  purchaseReceiptId       String?
  purchaseReceipt         PurchaseReceipt? @relation("NFeInboxReceipt", fields: [purchaseReceiptId], references: [id])
  nfeDocumentId           String?
  nfeDocument             NFeDocument?     @relation(fields: [nfeDocumentId], references: [id])

  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  // Relations
  items                   NFeInboxItem[]
  linkedReceipts          PurchaseReceipt[] @relation("NFeInboxReceiptLink")
  cteDocuments            CteDocument[]

  @@unique([companyId, chaveAcesso])
  @@index([companyId, status])
  @@map("nfe_inbox")
}

model NFeInboxItem {
  id                        String           @id @default(cuid())
  inboxId                   String
  inbox                     NFeInbox         @relation(fields: [inboxId], references: [id], onDelete: Cascade)

  numeroItem                Int
  codigoProdutoFornecedor   String           // código do produto na NF-e do fornecedor
  descricaoProduto          String
  ncm                       String           @db.VarChar(8)
  cfop                      String           @db.VarChar(4)
  unidade                   String           @db.VarChar(6)
  quantidade                Decimal          @db.Decimal(15, 4)
  valorUnitario             Decimal          @db.Decimal(15, 4)
  valorTotal                Decimal          @db.Decimal(15, 2)
  valorIcms                 Decimal          @default(0) @db.Decimal(15, 2)
  valorIpi                  Decimal          @default(0) @db.Decimal(15, 2)
  valorPis                  Decimal          @default(0) @db.Decimal(15, 2)
  valorCofins               Decimal          @default(0) @db.Decimal(15, 2)

  // Mapeamento para produto interno
  productId                 String?
  product                   Product?         @relation(fields: [productId], references: [id])
  productSupplierId         String?
  productSupplier           ProductSupplier? @relation(fields: [productSupplierId], references: [id])
  mapeado                   Boolean          @default(false)

  createdAt                 DateTime         @default(now())

  @@index([inboxId])
  @@map("nfe_inbox_items")
}

model PurchaseReceipt {
  id                String         @id @default(cuid())
  companyId         String
  company           Company        @relation(fields: [companyId], references: [id])

  numero            String         // auto-gerado: REC-YYYYMMDD-NNN
  purchaseOrderId   String?
  purchaseOrder     PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  nfeInboxId        String?
  nfeInbox          NFeInbox?      @relation("NFeInboxReceiptLink", fields: [nfeInboxId], references: [id])
  responsavelId     String?
  responsavel       User?          @relation("PurchaseReceiptResponsavel", fields: [responsavelId], references: [id])

  status            ReceiptStatus  @default(PENDENTE)
  dataRecebimento   DateTime       @default(now())
  dataConferencia   DateTime?
  observacoes       String?        @db.Text

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Relations
  items             PurchaseReceiptItem[]
  nfeInboxRefs      NFeInbox[]     @relation("NFeInboxReceipt")

  @@unique([companyId, numero])
  @@index([companyId, status])
  @@map("purchase_receipts")
}

model PurchaseReceiptItem {
  id                    String          @id @default(cuid())
  receiptId             String
  receipt               PurchaseReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  productId             String
  product               Product         @relation(fields: [productId], references: [id])

  quantidadeNota        Decimal         @db.Decimal(15, 4)  // quantidade conforme NF-e
  quantidadeRecebida    Decimal         @db.Decimal(15, 4)  // quantidade fisicamente recebida
  quantidadeAprovada    Decimal         @default(0) @db.Decimal(15, 4)  // aprovada após inspeção
  quantidadeDevolvida   Decimal         @default(0) @db.Decimal(15, 4)
  valorUnitario         Decimal         @db.Decimal(15, 4)
  valorFreteRateado     Decimal         @default(0) @db.Decimal(15, 2)  // frete rateado neste item
  custoTotal            Decimal         @db.Decimal(15, 2)  // custo total incluindo frete
  divergencia           Boolean         @default(false)
  motivoDivergencia     String?         @db.Text

  createdAt             DateTime        @default(now())

  @@map("purchase_receipt_items")
}

// ============================================================================
// APONTAMENTOS PRODUTIVOS (Sprint 11)
// ============================================================================

model JornadaTrabalho {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  nome        String    @db.VarChar(100)
  horaInicio  String    @db.VarChar(5)
  horaFim     String    @db.VarChar(5)
  intervaloH  Float     @default(1.0)
  segSex      Boolean   @default(true)
  sabado      Boolean   @default(false)
  domingo     Boolean   @default(false)
  ativo       Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employees   Employee[] @relation("EmployeeJornada")

  @@map("jornadas_trabalho")
}

model FeriadoCalendario {
  id          String      @id @default(cuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id])
  data        DateTime    @db.Date
  descricao   String      @db.VarChar(200)
  tipo        FeriadoTipo @default(FERIADO)
  createdAt   DateTime    @default(now())

  @@unique([companyId, data])
  @@map("feriados_calendario")
}

model EtapaOS {
  id             String       @id @default(cuid())
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  sequencia      Int
  descricao      String       @db.VarChar(300)
  tempoEstimadoH Float?
  status         EtapaStatus  @default(PENDENTE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  apontamentos   Apontamento[]

  @@index([serviceOrderId])
  @@map("etapas_os")
}

model EtapaCalderaria {
  id                String          @id @default(cuid())
  calderariaOrderId String
  calderariaOrder   CalderariaOrder @relation(fields: [calderariaOrderId], references: [id], onDelete: Cascade)
  sequencia         Int
  descricao         String          @db.VarChar(300)
  tempoEstimadoH    Float?
  status            EtapaStatus     @default(PENDENTE)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  apontamentos      Apontamento[]

  @@index([calderariaOrderId])
  @@map("etapas_calderaria")
}

model Apontamento {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])

  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])

  // Vínculo Produção
  productionOrderId String?
  productionOrder   ProductionOrder? @relation(fields: [productionOrderId], references: [id])
  routingStepId     String?
  routingStep       RoutingStep?     @relation(fields: [routingStepId], references: [id])

  // Vínculo Oficina
  serviceOrderId    String?
  serviceOrder      ServiceOrder?    @relation(fields: [serviceOrderId], references: [id])
  etapaOsId         String?
  etapaOs           EtapaOS?         @relation(fields: [etapaOsId], references: [id])

  // Vínculo Calderaria
  calderariaOrderId String?
  calderariaOrder   CalderariaOrder? @relation(fields: [calderariaOrderId], references: [id])
  etapaCalderariaId String?
  etapaCalderaria   EtapaCalderaria? @relation(fields: [etapaCalderariaId], references: [id])

  // Timing
  inicio      DateTime
  fim         DateTime?
  pausado     Boolean           @default(false)
  totalHoras  Decimal?          @db.Decimal(10, 4)

  // Produção
  quantidadeProduzida Float?
  quantidadeRejeitada Float?
  motivoParada        String?   @db.VarChar(300)

  status       ApontamentoStatus @default(EM_ANDAMENTO)
  observations String?           @db.Text

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId, employeeId, status])
  @@index([productionOrderId])
  @@index([serviceOrderId])
  @@index([calderariaOrderId])
  @@map("apontamentos")
}
