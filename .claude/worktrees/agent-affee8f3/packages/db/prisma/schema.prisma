// Alíquotas internas de ICMS por UF — usadas no cálculo do DIFAL
model AliquotaIcmsUf {
  id            String   @id @default(cuid())
  uf            String   @unique @db.VarChar(2)  // SP, MG, RJ...
  nome          String   @db.VarChar(100)         // São Paulo
