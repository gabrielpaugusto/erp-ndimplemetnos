generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum TaxSystem {
  ATUAL      // Sistema tributário atual (ICMS, ISS, PIS/COFINS, IPI)
  NOVO       // Sistema novo pós-reforma (IBS, CBS, IS)
  TRANSICAO  // Período de transição (2026-2032) — ambos coexistem
}

enum TaxRegime {
  LUCRO_REAL
  LUCRO_PRESUMIDO
  SIMPLES_NACIONAL
}

enum PersonType {
  PF  // Pessoa Física
  PJ  // Pessoa Jurídica
}

