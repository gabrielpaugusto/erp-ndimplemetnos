  aliquotaReduzida Float?                          // ex: 12.0 (para alguns produtos)
  aliquotaFcp   Float    @default(0)              // FCP (Fundo de Combate à Pobreza)
  codigoIbge    String?  @db.VarChar(2)           // código IBGE do estado
