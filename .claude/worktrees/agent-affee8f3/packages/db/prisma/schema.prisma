// ============================================================================
// TABELAS FISCAIS
// ============================================================================

model Ncm {
  id                    String    @id @default(cuid())
  code                  String    @unique @db.VarChar(10)   // "8716.39.00"
  description           String    @db.VarChar(500)
  exTipi                String?   @db.VarChar(5)

  // ── IPI ────────────────────────────────────────────────────────
  aliquotaIpi           Decimal?  @db.Decimal(5, 2)         // % IPI (ex: 0, 5, 10, 15)
  cstIpiEntrada         String?   @db.VarChar(2)            // CST IPI entrada padrão: "00","02","04"
  cstIpiSaida           String?   @db.VarChar(2)            // CST IPI saída padrão: "50","52","53"

  // ── ICMS — Regime Normal (LR / LP) ─────────────────────────────
  cstIcms               String?   @db.VarChar(2)            // CST ICMS padrão: "00","20","40","60"
  reducaoBcIcms         Decimal?  @db.Decimal(5, 2)         // % redução BC ICMS se houver (ex: 33.33)

  // ── ICMS — Simples Nacional ─────────────────────────────────────
  csosn                 String?   @db.VarChar(3)            // CSOSN padrão: "102","400","500"

  // ── PIS / COFINS ────────────────────────────────────────────────
  cstPisCofinsSaida     String?   @db.VarChar(2)            // CST PIS/COFINS saída: "01","04","07","08"
  cstPisCofinsEntrada   String?   @db.VarChar(2)            // CST PIS/COFINS entrada: "50","70","73"
  aliquotaPis           Decimal?  @db.Decimal(5, 4)         // % PIS não-cumulativo (ex: 1.6500)
  aliquotaCofins        Decimal?  @db.Decimal(5, 4)         // % COFINS não-cumulativo (ex: 7.6000)
  monofasico            Boolean   @default(false)            // tributação monofásica (combustíveis, farmácia)

  // ── Substituição Tributária (ST) ────────────────────────────────
  temSt                 Boolean   @default(false)            // sujeito a ST?
  cestCode              String?   @db.VarChar(7)             // código CEST (sem pontos: "0100100")
  cestDescricao         String?   @db.VarChar(300)           // descrição do segmento CEST

  // ── Importação ──────────────────────────────────────────────────
  aliquotaImportacao    Decimal?  @db.Decimal(5, 2)          // II — Imposto de Importação %

  // ── Reforma Tributária (EC 132/2023) ────────────────────────────
  // CBS — Contribuição sobre Bens e Serviços (federal, substitui PIS+COFINS+IPI)
  aliquotaCbs           Decimal?  @db.Decimal(6, 4)          // % CBS (referência ~8.8%)
  cstCbs                String?   @db.VarChar(2)             // CST CBS futuro
  // IBS — Imposto sobre Bens e Serviços (estados+municípios, substitui ICMS+ISS)
  aliquotaIbs           Decimal?  @db.Decimal(6, 4)          // % IBS (referência ~17.7%)
  cstIbs                String?   @db.VarChar(2)             // CST IBS futuro
  // IS — Imposto Seletivo (sin tax: tabaco, álcool, veículos poluentes, apostas)
  temIs                 Boolean   @default(false)             // sujeito ao Imposto Seletivo?
  aliquotaIs            Decimal?  @db.Decimal(6, 4)          // % IS (varia por produto)
  categoriaIs           String?   @db.VarChar(50)            // TABACO, ALCOOL, VEICULO, APOSTAS, OUTROS
  // Categoria para reforma
  categoriaReforma      String?   @db.VarChar(30)            // BEM, SERVICO, BEM_IMATERIAL
  regimeEspecialReforma String?   @db.VarChar(100)           // eventual regime diferenciado

  // ── Geral ───────────────────────────────────────────────────────
  observacoes           String?   @db.Text
  active                Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  products              Product[]

  @@index([code])
  @@map("ncms")
}

model Cfop {
  id          String   @id @default(cuid())
  code        String   @unique @db.VarChar(4)  // "5101", "6102"
  description String   @db.VarChar(500)
