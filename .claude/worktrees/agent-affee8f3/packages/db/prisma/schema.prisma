  items           InventoryItem[]

  @@unique([companyId, numero])
  @@map("inventories")
}

model InventoryItem {
  id                String    @id @default(cuid())
  inventoryId       String
  inventory         Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  productId         String
  product           Product   @relation(fields: [productId], references: [id])
