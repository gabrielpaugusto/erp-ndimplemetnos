# ============================================================================
# .env.production.example
# Copie para .env.production no servidor e preencha TODOS os valores.
# NUNCA suba o .env.production para o Git.
# ============================================================================

# ── Banco de dados ──────────────────────────────────────────────────────────
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI
POSTGRES_DB=erp_prod
DATABASE_URL=postgresql://erp_user:TROQUE_POR_SENHA_FORTE_AQUI@postgres:5432/erp_prod

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=TROQUE_POR_SENHA_REDIS_AQUI

# ── MinIO (armazenamento de arquivos) ───────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=TROQUE_POR_ACCESS_KEY_AQUI
MINIO_SECRET_KEY=TROQUE_POR_SECRET_KEY_AQUI
MINIO_BUCKET=erp-files

# ── JWT / Autenticação ──────────────────────────────────────────────────────
JWT_SECRET=TROQUE_POR_STRING_ALEATORIA_LONGA_AQUI
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET=TROQUE_POR_OUTRA_STRING_ALEATORIA_AQUI
REFRESH_TOKEN_EXPIRES_IN=7d

# ── API NestJS ──────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3001
API_PREFIX=api

# ── Anthropic (FiscalBrain IA) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-TROQUE_PELA_CHAVE_REAL

# ── Governo / SEFAZ (NF-e, NFS-e) ──────────────────────────────────────────
GOV_AMBIENTE=homologacao
# GOV_AMBIENTE=producao   ← trocar quando certificado estiver validado

GOV_CERTIFICADO_A1_PATH=/app/certs/certificado.pfx
GOV_CERTIFICADO_A1_SENHA=SENHA_DO_CERTIFICADO

# Chave de criptografia para o certificado no banco (32 bytes em hex)
ENCRYPTION_KEY=TROQUE_POR_64_CARACTERES_HEX_AQUI

# ── Next.js (Frontend) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://erp.seudominio.com.br/api
NEXTAUTH_URL=https://erp.seudominio.com.br
NEXTAUTH_SECRET=TROQUE_POR_STRING_ALEATORIA_AQUI

# ── Configurações da Empresa ─────────────────────────────────────────────────
COMPANY_NAME=ND Implementos
COMPANY_CNPJ=00000000000000
